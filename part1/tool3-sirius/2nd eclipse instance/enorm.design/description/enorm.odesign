           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="InputArrow" labelSize="9">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='cyan']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='cyan']"/>

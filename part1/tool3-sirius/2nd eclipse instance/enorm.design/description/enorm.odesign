         <edgeMappings name="SortingPolicyAppliesToFeedback" semanticCandidatesExpression="aql:if self.appliesToFeedback &lt;> null then Sequence{self.appliesToFeedback} else Sequence{} endif" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='SortingPolicy']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='FeedbackDefinition']" domainClass="enorm.FeedbackDefinition">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="InputArrow" labelSize="9" strokeDashStyle="Dash">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
           </style>

         <edgeMappings name="AutomationRuleActions" semanticCandidatesExpression="aql:self.actions" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='AutomationRule']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='Action']" domainClass="enorm.Action">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="FillDiamond" labelSize="9">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
           </style>
         </edgeMappings>
         <edgeMappings name="SortingPolicyAppliesToResource" semanticCandidatesExpression="aql:if self.appliesToResource &lt;> null then Sequence{self.appliesToResource} else Sequence{} endif" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='SortingPolicy']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='ResourceType']" domainClass="enorm.ResourceType">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="InputArrow" labelSize="9" strokeDashStyle="Dash">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
           </style>

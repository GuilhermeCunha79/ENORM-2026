         <edgeMappings name="AutomationRuleContext" semanticCandidatesExpression="aql:if self.context &lt;> null then Sequence{self.context} else Sequence{} endif" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='AutomationRule']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='ResourceType']" domainClass="enorm.ResourceType">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="InputArrow" labelSize="9" strokeDashStyle="Dot">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
           </style>
         </edgeMappings>
         <edgeMappings name="AutomationRuleInContext" semanticCandidatesExpression="aql:if self.inContext &lt;> null then Sequence{self.inContext} else Sequence{} endif" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='AutomationRule']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='ContextType']" domainClass="enorm.ContextType">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="InputArrow" labelSize="9" strokeDashStyle="Dot">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
           </style>
         </edgeMappings>
         <edgeMappings name="ValidationRuleInvokedBy" semanticCandidatesExpression="aql:if self.invokedBy &lt;> null then Sequence{self.invokedBy} else Sequence{} endif" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='ValidationRule']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='AutomationRule']" domainClass="enorm.AutomationRule">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="InputArrow" labelSize="9" strokeDashStyle="Dash">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
           </style>
         </edgeMappings>
         <edgeMappings name="AutomationRuleConditions" semanticCandidatesExpression="aql:self.conditions" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='AutomationRule']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='Condition']" domainClass="enorm.Condition">
           <style xsi:type="style:EdgeStyle" sourceArrow="NoDecoration" targetArrow="FillDiamond" labelSize="9">
             <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
             <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
           </style>

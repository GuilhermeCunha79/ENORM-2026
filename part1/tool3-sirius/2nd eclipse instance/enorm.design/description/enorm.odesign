         <edgeMappings name="SortingPolicyInContext" semanticCandidatesExpression="aql:if self.inContext &lt;> null then Sequence{self.inContext} else Sequence{} endif" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='SortingPolicy']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='RefDiagram']/@defaultLayer/@nodeMappings[name='ContextType']" domainClass="enorm.ContextType">

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="kind" eType="#//ContextKind"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="contains" lowerBound="1" upperBound="-1" eType="#//ResourceType"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="ContextKind">
    <eLiterals name="GLOBAL"/>
    <eLiterals name="COMMUNITY" value="1"/>
    <eLiterals name="CHANNEL" value="2"/>
    <eLiterals name="CATALOG" value="3"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ResourceType">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="supportsMedia" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="superTypes" upperBound="-1" eType="#//ResourceType"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="attributes" lowerBound="1" upperBound="-1" eType="#//Attribute" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Attribute">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="type" eType="#//PrimitiveType"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="required" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="multiValued" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="PrimitiveType">
    <eLiterals name="TEXT"/>
    <eLiterals name="NUMBER" value="1"/>
    <eLiterals name="BOOLEAN" value="2"/>
    <eLiterals name="DATE" value="3"/>
    <eLiterals name="DATETIME" value="4"/>
    <eLiterals name="IMAGE" value="5"/>
    <eLiterals name="VIDEO" value="6"/>
    <eLiterals name="URL" value="7"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ResourceRelation">

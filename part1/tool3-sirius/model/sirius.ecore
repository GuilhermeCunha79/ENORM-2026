<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="sirius" nsURI="http://www.example.org/sirius" nsPrefix="sirius">
  <eClassifiers xsi:type="ecore:EClass" name="RefModel">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="version" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="userTypes" upperBound="-1" eType="#//UserType" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="resourceTypes" upperBound="-1" eType="#//ResourceType" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="contextTypes" upperBound="-1" eType="#//ContextType" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="resourceRelations" upperBound="-1" eType="#//ResourceRelation" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="feedbackTypes" upperBound="-1" eType="#//FeedbackType" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="feedbackDefinitions" upperBound="-1" eType="#//FeedbackDefinition" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="authorizationRules" upperBound="-1" eType="#//AuthorizationRule" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="validationRules" upperBound="-1" eType="#//ValidationRule" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="moderationPolicies" upperBound="-1" eType="#//ModerationPolicy" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="automationRules" upperBound="-1" eType="#//AutomationRule" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="verificationPolicies" upperBound="-1" eType="#//VerificationPolicy" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="UserType">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="kind" eType="#//UserKind"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="superTypes" upperBound="-1" eType="#//UserType"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="UserKind">
    <eLiterals name="GENERIC"/>
    <eLiterals name="BUYER" value="1"/>
    <eLiterals name="SELLER" value="2"/>
    <eLiterals name="CREATOR" value="3"/>
    <eLiterals name="MODERATOR" value="4"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ContextType">

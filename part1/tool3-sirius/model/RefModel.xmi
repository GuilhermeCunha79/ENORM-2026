<?xml version="1.0" encoding="UTF-8"?>
<enorm:RefModel
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:enorm="http://www.example.org/enorm"
    name="DSL"
    version="1.0.0">

  <!-- User Types -->
  <userTypes name="Buyer" kind="BUYER"/>
  <userTypes name="Seller" kind="SELLER"/>
  <userTypes name="Creator" kind="CREATOR"/>
  <userTypes name="Moderator" kind="MODERATOR"/>
  <userTypes name="Admin" kind="GENERIC"/>

  <!-- Resource Types -->
  <resourceTypes name="Product" supportsMedia="true">
    <attributes name="title" type="TEXT" required="true" multiValued="false"/>
    <attributes name="description" type="TEXT" required="true" multiValued="false"/>
    <attributes name="price" type="NUMBER" required="true" multiValued="false"/>
    <attributes name="category" type="TEXT" required="true" multiValued="false"/>
    <attributes name="images" type="IMAGE" required="false" multiValued="true"/>
    <attributes name="videoUrl" type="VIDEO" required="false" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="Review" supportsMedia="true">
    <attributes name="title" type="TEXT" required="true" multiValued="false"/>
    <attributes name="content" type="TEXT" required="true" multiValued="true"/>
    <attributes name="rating" type="NUMBER" required="true" multiValued="false"/>
    <attributes name="purchaseDate" type="DATE" required="true" multiValued="false"/>
    <attributes name="helpful" type="NUMBER" required="false" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="Comment" supportsMedia="false">
    <attributes name="text" type="TEXT" required="true" multiValued="false"/>
    <attributes name="timestamp" type="DATETIME" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="Shop" supportsMedia="true">
    <attributes name="name" type="TEXT" required="true" multiValued="false"/>
    <attributes name="description" type="TEXT" required="false" multiValued="false"/>
    <attributes name="rating" type="NUMBER" required="false" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="User" supportsMedia="false">
    <attributes name="name" type="TEXT" required="true" multiValued="false"/>
  </resourceTypes>

  <!-- Context Types -->
  <contextTypes name="Global" kind="GLOBAL" contains="//@resourceTypes.0 //@resourceTypes.1 //@resourceTypes.2 //@resourceTypes.3 //@resourceTypes.4"/>
  <contextTypes name="Marketplace" kind="COMMUNITY" contains="//@resourceTypes.0 //@resourceTypes.3 //@resourceTypes.4"/>
  <contextTypes name="ProductReviews" kind="CHANNEL" contains="//@resourceTypes.1 //@resourceTypes.2"/>

  <!-- Resource Relations -->
  <resourceRelations name="Product_Reviews" sourceCardinality="1" targetCardinality="*" containment="false" recursive="false" source="//@resourceTypes.0" target="//@resourceTypes.1"/>
  <resourceRelations name="Review_Comments" sourceCardinality="1" targetCardinality="*" containment="false" recursive="false" source="//@resourceTypes.1" target="//@resourceTypes.2"/>
  <resourceRelations name="Seller_Shop" sourceCardinality="1" targetCardinality="1" containment="false" recursive="false" source="//@resourceTypes.4" target="//@resourceTypes.3"/>

  <!-- Feedback Types -->
  <feedbackTypes name="ProductReview" kind="REVIEW" subjectScope="RESOURCE_ONLY" hasRating="true" recursive="false" allowsText="true" allowsMedia="true" polarity="NONE"/>
  <feedbackTypes name="ReviewComment" kind="COMMENT" subjectScope="RESOURCE_OR_FEEDBACK" hasRating="false" recursive="true" allowsText="true" allowsMedia="false" polarity="NONE"/>
  <feedbackTypes name="Reaction" kind="REACTION" subjectScope="RESOURCE_OR_FEEDBACK" hasRating="false" recursive="false" allowsText="false" allowsMedia="false" polarity="LIKE_DISLIKE"/>
  <feedbackTypes name="Vote" kind="VOTE" subjectScope="RESOURCE_OR_FEEDBACK" hasRating="false" recursive="false" allowsText="false" allowsMedia="false" polarity="UP_DOWN"/>
  <feedbackTypes name="Complaint" kind="REPORT" subjectScope="RESOURCE_OR_FEEDBACK" hasRating="false" recursive="false" allowsText="true" allowsMedia="true" polarity="NONE"/>

  <!-- Feedback Definitions -->
  <feedbackDefinitions name="ProductRating" requiresVerifiedContext="true" verificationRequirement="REQUIRED" uniquePerAuthorTarget="true" type="//@feedbackTypes.0" subjectResource="//@resourceTypes.0" author="//@userTypes.0">
    <policy status="ENABLED"/>
    <rating minValue="1" maxValue="5" step="1"/>
  </feedbackDefinitions>

  <feedbackDefinitions name="ReviewComment" requiresVerifiedContext="false" verificationRequirement="NONE" uniquePerAuthorTarget="false" type="//@feedbackTypes.1" subjectResource="//@resourceTypes.1" author="//@userTypes.0">
    <policy status="ENABLED"/>
    <rating minValue="1" maxValue="1" step="1"/>
  </feedbackDefinitions>

  <feedbackDefinitions name="SellerReport" requiresVerifiedContext="true" verificationRequirement="OPTIONAL" uniquePerAuthorTarget="false" type="//@feedbackTypes.4" subjectResource="//@resourceTypes.3" author="//@userTypes.0">
    <policy status="ENABLED"/>
    <rating minValue="1" maxValue="1" step="1"/>
  </feedbackDefinitions>

  <!-- Validation Rules -->
  <validationRules name="ProductPriceValidation" kind="AUTOMATIC" severity="ERROR" expression="self.price > 0" appliesToResource="//@resourceTypes.0" invokedBy="//@automationRules.1"/>
  <validationRules name="ReviewRatingRange" kind="AUTOMATIC" severity="WARNING" expression="self.rating >= 1 and self.rating &lt;= 5" appliesToFeedback="//@feedbackDefinitions.0" invokedBy="//@automationRules.0"/>
  <validationRules name="ReviewMinLength" kind="AUTOMATIC" severity="ERROR" expression="self.content.size() >= 10" appliesToResource="//@resourceTypes.1" invokedBy="//@automationRules.2"/>
  <validationRules name="CommentNotEmpty" kind="AUTOMATIC" severity="ERROR" expression="self.text.size() > 0" appliesToResource="//@resourceTypes.2" invokedBy="//@automationRules.3"/>
  <validationRules name="ShopNameRequired" kind="MANUAL" severity="ERROR" appliesToResource="//@resourceTypes.3" invokedBy="//@automationRules.4"/>

  <!-- Authorization Rules -->
  <authorizationRules name="BuyerReadProduct" allowedAction="READ" actor="//@userTypes.0" context="//@contextTypes.0" resourceTarget="//@resourceTypes.0" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules name="SellerCreateProduct" allowedAction="CREATE" actor="//@userTypes.1" context="//@contextTypes.1" resourceTarget="//@resourceTypes.0" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules name="SellerUpdateProduct" allowedAction="UPDATE" actor="//@userTypes.1" context="//@contextTypes.1" resourceTarget="//@resourceTypes.0" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules name="ModeratorDeleteComment" allowedAction="DELETE" actor="//@userTypes.3" context="//@contextTypes.0" resourceTarget="//@resourceTypes.2" feedbackTarget="//@feedbackDefinitions.1"/>
  <authorizationRules name="BuyerRateReview" allowedAction="RATE" actor="//@userTypes.0" context="//@contextTypes.2" resourceTarget="//@resourceTypes.1" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules name="BuyerCommentReview" allowedAction="COMMENT" actor="//@userTypes.0" context="//@contextTypes.2" resourceTarget="//@resourceTypes.2" feedbackTarget="//@feedbackDefinitions.1"/>
  <authorizationRules name="ModeratorModerateReview" allowedAction="MODERATE" actor="//@userTypes.3" context="//@contextTypes.0" resourceTarget="//@resourceTypes.1" feedbackTarget="//@feedbackDefinitions.0"/>

  <!-- Moderation Policies -->
  <moderationPolicies name="SpamDetectionPolicy" mode="AUTOMATIC" trigger="ON_FEEDBACK_CREATE" decision="FLAGGED" monitorsResource="//@resourceTypes.1" monitorsFeedback="//@feedbackDefinitions.1" executedBy="//@userTypes.3" inContext="//@contextTypes.2"/>
  <moderationPolicies name="OffensiveContentPolicy" mode="HYBRID" trigger="ON_FEEDBACK_CREATE" decision="HIDDEN" monitorsResource="//@resourceTypes.2" monitorsFeedback="//@feedbackDefinitions.1" executedBy="//@userTypes.3" inContext="//@contextTypes.2"/>
  <moderationPolicies name="FakeReviewPolicy" mode="MANUAL" trigger="ON_REPORT_SUBMITTED" decision="REMOVED" monitorsResource="//@resourceTypes.1" monitorsFeedback="//@feedbackDefinitions.0" executedBy="//@userTypes.3" inContext="//@contextTypes.2"/>

  <!-- Automation Rules -->
  <automationRules name="LowRatingNotification" trigger="ON_FEEDBACK_CREATE" context="//@resourceTypes.0" inContext="//@contextTypes.1" onFeedback="//@feedbackDefinitions.0" uses="//@validationRules.1">
    <conditions name="RatingBelowTwo" field="rating" operator="HAS_SPECIFIC_PROPERTY" value="lt:2"/>
    <actions name="NotifySeller" kind="NOTIFY_MODERATOR" message="Low rating detected, seller notification triggered"/>
  </automationRules>
  <automationRules name="HighRatingBadge" trigger="ON_FEEDBACK_CREATE" context="//@resourceTypes.0" inContext="//@contextTypes.1" onFeedback="//@feedbackDefinitions.0" uses="//@validationRules.0">
    <conditions name="RatingAboveFour" field="rating" operator="HAS_SPECIFIC_PROPERTY" value="gt:4.5"/>
    <actions name="AwardBadge" kind="AUTO_APPROVE" message="High rating badge awarded to seller"/>
  </automationRules>
  <automationRules name="ReviewLengthEscalation" trigger="ON_FEEDBACK_CREATE" context="//@resourceTypes.1" inContext="//@contextTypes.2" onFeedback="//@feedbackDefinitions.1" uses="//@validationRules.2">
    <conditions name="ReviewTooShort" field="content" operator="HAS_SPECIFIC_PROPERTY" value="length:lt:10"/>
    <actions name="FlagShortReview" kind="FLAG_CONTENT" message="Review is too short and has been flagged for moderation"/>
  </automationRules>
  <automationRules name="CommentQualityCheck" trigger="ON_FEEDBACK_CREATE" context="//@resourceTypes.2" inContext="//@contextTypes.2" onFeedback="//@feedbackDefinitions.1" uses="//@validationRules.3">
    <conditions name="CommentEmpty" field="text" operator="NOT_HAS_PROPERTY" value="text"/>
    <actions name="BlockEmptyComment" kind="BLOCK_SUBMISSION" message="Comment text is required and cannot be empty"/>
  </automationRules>
  <automationRules name="ShopProfileCheck" trigger="ON_RESOURCE_CREATE" context="//@resourceTypes.3" inContext="//@contextTypes.1" onFeedback="//@feedbackDefinitions.2" uses="//@validationRules.4">
    <conditions name="ShopNameMissing" field="name" operator="NOT_HAS_PROPERTY" value="name"/>
    <actions name="RequestProfileCompletion" kind="DISPLAY_MESSAGE" message="Shop name is required, please complete your profile"/>
  </automationRules>

  <!-- Verification Policies -->
  <verificationPolicies name="BuyerVerification" mode="AUTOMATIC" appliesWhen="ON_FEEDBACK_CREATE" verifies="//@feedbackDefinitions.0"/>
  <verificationPolicies name="SellerVerification" mode="MANUAL" appliesWhen="ON_MANUAL_REQUEST" verifies="//@feedbackDefinitions.2"/>

  <!-- Sorting Policies -->
  <sortingPolicies name="ReviewsByDate" criterion="DATE" direction="DESC" appliesToResource="//@resourceTypes.1" inContext="//@contextTypes.2"/>
  <sortingPolicies name="ProductsByRating" criterion="VALUE" direction="DESC" appliesToFeedback="//@feedbackDefinitions.0" inContext="//@contextTypes.1"/>
  <sortingPolicies name="CommentsByRelevance" criterion="RELEVANCE" direction="DESC" appliesToResource="//@resourceTypes.2" inContext="//@contextTypes.2"/>

</enorm:RefModel>

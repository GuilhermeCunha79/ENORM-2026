<?xml version="1.0" encoding="UTF-8"?>
<enorm:RefModel
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:enorm="http://www.example.org/enorm"
    name="YouTubeScenario"
    version="1.0.0">

  <!-- User Types -->
  <userTypes name="User" kind="GENERIC"/>
  <userTypes name="Creator" kind="CREATOR" superTypes="//@userTypes.0"/>
  <userTypes name="Moderator" kind="MODERATOR" superTypes="//@userTypes.0"/>

  <!-- Resource Types -->
  <resourceTypes name="Channel" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="name" type="TEXT" required="true" multiValued="false"/>
    <attributes name="description" type="TEXT" required="false" multiValued="false"/>
    <attributes name="creationDate" type="DATE" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="Content" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="creationDate" type="DATE" required="true" multiValued="false"/>
    <attributes name="status" type="TEXT" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="Video" supportsMedia="true" superTypes="//@resourceTypes.1">
    <attributes name="title" type="TEXT" required="true" multiValued="false"/>
    <attributes name="description" type="TEXT" required="true" multiValued="false"/>
    <attributes name="uploadDate" type="DATE" required="true" multiValued="false"/>
    <attributes name="duration" type="NUMBER" required="true" multiValued="false"/>
    <attributes name="commentStatus" type="TEXT" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="Comment" supportsMedia="false" superTypes="//@resourceTypes.1">
    <attributes name="text" type="TEXT" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="LikeHistory" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="action" type="TEXT" required="true" multiValued="false"/>
    <attributes name="timestamp" type="DATETIME" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="VideoModerationCheck" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="type" type="TEXT" required="true" multiValued="false"/>
    <attributes name="result" type="TEXT" required="true" multiValued="false"/>
    <attributes name="timestamp" type="DATE" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="CommentModerationCheck" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="type" type="TEXT" required="true" multiValued="false"/>
    <attributes name="result" type="TEXT" required="true" multiValued="false"/>
    <attributes name="timestamp" type="DATE" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="CommentSettingsChange" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="newStatus" type="TEXT" required="true" multiValued="false"/>
    <attributes name="timestamp" type="DATE" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="ChannelPermissionPolicy" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="action" type="TEXT" required="true" multiValued="false"/>
    <attributes name="allowedFor" type="TEXT" required="true" multiValued="false"/>
  </resourceTypes>

  <resourceTypes name="ContentValidationRuleArtifact" supportsMedia="false">
    <attributes name="id" type="TEXT" required="true" multiValued="false"/>
    <attributes name="target" type="TEXT" required="true" multiValued="false"/>
    <attributes name="policyType" type="TEXT" required="true" multiValued="false"/>
    <attributes name="severity" type="TEXT" required="true" multiValued="false"/>
  </resourceTypes>

  <!-- Context Types -->
  <contextTypes name="Global" kind="GLOBAL" contains="//@resourceTypes.0 //@resourceTypes.1 //@resourceTypes.2 //@resourceTypes.3 //@resourceTypes.4 //@resourceTypes.5 //@resourceTypes.6 //@resourceTypes.7 //@resourceTypes.8 //@resourceTypes.9"/>
  <contextTypes name="ChannelSpace" kind="CHANNEL" contains="//@resourceTypes.0 //@resourceTypes.2 //@resourceTypes.3 //@resourceTypes.5 //@resourceTypes.6 //@resourceTypes.7 //@resourceTypes.8 //@resourceTypes.9"/>

  <!-- Resource Relations -->
  <resourceRelations name="Channel_contains_Video" sourceCardinality="1" targetCardinality="*" containment="true" recursive="false" source="//@resourceTypes.0" target="//@resourceTypes.2"/>
  <resourceRelations name="Video_has_Comment" sourceCardinality="1" targetCardinality="*" containment="true" recursive="false" source="//@resourceTypes.2" target="//@resourceTypes.3"/>
  <resourceRelations name="Comment_replies_Comment" sourceCardinality="0..1" targetCardinality="*" containment="false" recursive="true" source="//@resourceTypes.3" target="//@resourceTypes.3"/>
  <resourceRelations name="Channel_has_PermissionPolicy" sourceCardinality="1" targetCardinality="*" containment="true" recursive="false" source="//@resourceTypes.0" target="//@resourceTypes.8"/>
  <resourceRelations name="Video_checked_by_VideoModerationCheck" sourceCardinality="1" targetCardinality="*" containment="false" recursive="false" source="//@resourceTypes.2" target="//@resourceTypes.5"/>
  <resourceRelations name="Comment_checked_by_CommentModerationCheck" sourceCardinality="1" targetCardinality="*" containment="false" recursive="false" source="//@resourceTypes.3" target="//@resourceTypes.6"/>
  <resourceRelations name="CommentSettingsChange_on_Video" sourceCardinality="*" targetCardinality="1" containment="false" recursive="false" source="//@resourceTypes.7" target="//@resourceTypes.2"/>
  <resourceRelations name="LikeHistory_on_Content" sourceCardinality="*" targetCardinality="1" containment="false" recursive="false" source="//@resourceTypes.4" target="//@resourceTypes.1"/>
  <resourceRelations name="Video_validated_by_RuleArtifact" sourceCardinality="1" targetCardinality="*" containment="false" recursive="false" source="//@resourceTypes.2" target="//@resourceTypes.9"/>
  <resourceRelations name="Comment_validated_by_RuleArtifact" sourceCardinality="1" targetCardinality="*" containment="false" recursive="false" source="//@resourceTypes.3" target="//@resourceTypes.9"/>

  <!-- Feedback Types -->
  <feedbackTypes name="Like" kind="VOTE" subjectScope="RESOURCE_ONLY" hasRating="false" recursive="false" allowsMedia="false"/>
  <feedbackTypes name="Subscription" kind="SUBSCRIPTION" subjectScope="RESOURCE_ONLY" hasRating="false" recursive="false" allowsMedia="false"/>
  <feedbackTypes name="Report" kind="REPORT" subjectScope="RESOURCE_ONLY" hasRating="false" recursive="false" allowsMedia="false"/>

  <!-- Feedback Definitions -->
  <feedbackDefinitions name="LikeOnContent" requiresVerifiedContext="false" uniquePerAuthorTarget="true" type="//@feedbackTypes.0" subjectResource="//@resourceTypes.1" author="//@userTypes.0">
    <policy status="ENABLED"/>
    <rating minValue="1" maxValue="1" step="1"/>
  </feedbackDefinitions>

  <feedbackDefinitions name="SubscriptionToChannel" requiresVerifiedContext="false" uniquePerAuthorTarget="true" type="//@feedbackTypes.1" subjectResource="//@resourceTypes.0" author="//@userTypes.0">
    <policy status="ENABLED"/>
    <rating minValue="1" maxValue="1" step="1"/>
  </feedbackDefinitions>

  <feedbackDefinitions name="ReportOnContent" requiresVerifiedContext="false" uniquePerAuthorTarget="false" type="//@feedbackTypes.2" subjectResource="//@resourceTypes.1" author="//@userTypes.0">
    <policy status="ENABLED"/>
    <rating minValue="1" maxValue="1" step="1"/>
  </feedbackDefinitions>

  <!-- Validation Rules -->
  <validationRules name="VideoPolicyValidation" kind="AUTOMATIC" severity="WARNING" expression="video_passes_copyright_and_spam_checks" appliesToResource="//@resourceTypes.2" invokedBy="//@automationRules.0"/>
  <validationRules name="CommentPolicyValidation" kind="AUTOMATIC" severity="WARNING" expression="comment_passes_toxicity_and_spam_checks" appliesToResource="//@resourceTypes.3" invokedBy="//@automationRules.1"/>

  <!-- Authorization Rules -->
  <authorizationRules allowedAction="CREATE" actor="//@userTypes.1" context="//@contextTypes.1" resourceTarget="//@resourceTypes.2" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules allowedAction="COMMENT" actor="//@userTypes.0" context="//@contextTypes.1" resourceTarget="//@resourceTypes.3" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules allowedAction="VOTE" actor="//@userTypes.0" context="//@contextTypes.1" resourceTarget="//@resourceTypes.1" feedbackTarget="//@feedbackDefinitions.0"/>
  <authorizationRules allowedAction="REPORT" actor="//@userTypes.0" context="//@contextTypes.1" resourceTarget="//@resourceTypes.1" feedbackTarget="//@feedbackDefinitions.2"/>
  <authorizationRules allowedAction="SUBSCRIBE" actor="//@userTypes.0" context="//@contextTypes.1" resourceTarget="//@resourceTypes.0" feedbackTarget="//@feedbackDefinitions.1"/>
  <authorizationRules allowedAction="MODERATE" actor="//@userTypes.2" context="//@contextTypes.1" resourceTarget="//@resourceTypes.1" feedbackTarget="//@feedbackDefinitions.2"/>

  <!-- Moderation Policies -->
  <moderationPolicies name="VideoModerationPolicy" mode="HYBRID" trigger="COPYRIGHT_OR_CONTENT_OR_SPAM" decision="FLAGGED" monitorsResource="//@resourceTypes.2" monitorsFeedback="//@feedbackDefinitions.2" executedBy="//@userTypes.2" inContext="//@contextTypes.1"/>
  <moderationPolicies name="CommentModerationPolicy" mode="HYBRID" trigger="SPAM_OR_TOXICITY_OR_BLOCKED_WORD" decision="HIDDEN" monitorsResource="//@resourceTypes.3" monitorsFeedback="//@feedbackDefinitions.2" executedBy="//@userTypes.2" inContext="//@contextTypes.1"/>

  <!-- Automation Rules -->
  <automationRules name="VideoValidationAutomation" trigger="video_uploaded" condition="content_status_active" actionDescription="run validation and create moderation check" context="//@resourceTypes.2" inContext="//@contextTypes.1" onFeedback="//@feedbackDefinitions.2" uses="//@validationRules.0"/>
  <automationRules name="CommentValidationAutomation" trigger="comment_created" condition="commenting_enabled_on_video" actionDescription="run validation and create moderation check" context="//@resourceTypes.3" inContext="//@contextTypes.1" onFeedback="//@feedbackDefinitions.2" uses="//@validationRules.1"/>

  <!-- Verification Policies -->
  <verificationPolicies name="ReportReviewVerification" mode="MANUAL" appliesWhen="report_status_reviewed_by_moderator" verifies="//@feedbackDefinitions.2"/>

</enorm:RefModel>

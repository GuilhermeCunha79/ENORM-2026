@startuml
title CommentNotEmpty Validation Process
Mode: AUTOMATIC\nDecision/Condition: self.text.size() > 0\n
state "Validation Triggered" as trigger
state "Collect Input Data" as collect
state "Check Expression" as check
state "Expression Valid?" as decision <<choice>>
state "Validation Passed" as pass
state "Validation Failed (ERROR)" as fail
state "Report Result" as report
[*] --> trigger
trigger --> collect
collect --> check
check --> decision
decision --> pass : true
decision --> fail : false
pass --> report
fail --> report
report --> [*]
@enduml

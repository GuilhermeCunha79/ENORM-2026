@startuml
title DSL v1.0.0 - Structure Diagram

' ===== RESOURCE TYPES =====
class "Product" as rt_0 << (R,#FF7700) >> {
  title: TEXT [required]
  description: TEXT [required]
  price: NUMBER [required]
  category: TEXT [required]
  images: IMAGE
  videoUrl: VIDEO
}
class "Review" as rt_1 << (R,#FF7700) >> {
  title: TEXT [required]
  content: TEXT [required]
  rating: NUMBER [required]
  purchaseDate: DATE [required]
  helpful: NUMBER
}
class "Comment" as rt_2 << (R,#FF7700) >> {
  text: TEXT [required]
  timestamp: DATETIME [required]
}
class "Shop" as rt_3 << (R,#FF7700) >> {
  name: TEXT [required]
  description: TEXT
  rating: NUMBER
}
class "User" as rt_4 << (R,#FF7700) >> {
  name: TEXT [required]
}

' ===== USER TYPES =====
class "Buyer" as ut_0 << (U,#00CCFF) >> {
  kind: BUYER
}
class "Seller" as ut_1 << (U,#00CCFF) >> {
  kind: SELLER
}
class "Creator" as ut_2 << (U,#00CCFF) >> {
  kind: CREATOR
}
class "Moderator" as ut_3 << (U,#00CCFF) >> {
  kind: MODERATOR
}
class "Admin" as ut_4 << (U,#00CCFF) >> {
  kind: GENERIC
}

' ===== FEEDBACK TYPES =====
class "ProductReview" as ft_0 << (F,#00FF00) >> {
  kind: REVIEW
}
class "ReviewComment" as ft_1 << (F,#00FF00) >> {
  kind: COMMENT
}
class "Reaction" as ft_2 << (F,#00FF00) >> {
  kind: REACTION
}
class "Vote" as ft_3 << (F,#00FF00) >> {
  kind: VOTE
}
class "Complaint" as ft_4 << (F,#00FF00) >> {
  kind: REPORT
}

' ===== FEEDBACK DEFINITIONS =====
class "ProductRating" as fd_0 << (D,#CCFFCC) >>
class "ReviewComment" as fd_1 << (D,#CCFFCC) >>
class "SellerReport" as fd_2 << (D,#CCFFCC) >>

' ===== RELATIONSHIPS =====
rt_0 "1" --> "*" rt_1
rt_1 "1" --> "*" rt_2
rt_4 "1" --> "1" rt_3

ft_0 *--> fd_0: feedback
fd_0 --> ut_0: author
fd_0 --> rt_0: subjectResource
ft_1 *--> fd_1: feedback
fd_1 --> ut_0: author
fd_1 --> rt_1: subjectResource
ft_4 *--> fd_2: feedback
fd_2 --> ut_0: author
fd_2 --> rt_3: subjectResource
@enduml

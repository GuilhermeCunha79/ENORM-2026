@startuml
title REF Model - AmazonScenario
skinparam classAttributeIconSize 0

class RefModel {
  name = AmazonScenario
  version = "1.0.0"
}

class UserType_Buyer {
  name = Buyer
  kind = BUYER
}
RefModel --> UserType_Buyer
class UserType_Seller {
  name = Seller
  kind = SELLER
}
RefModel --> UserType_Seller
class UserType_Moderator {
  name = Moderator
  kind = MODERATOR
}
RefModel --> UserType_Moderator

class ResourceType_Product {
  name = Product
  supportsMedia = true
}
RefModel --> ResourceType_Product
class Attribute_Product_title {
  name = title
  type = TEXT
  required = true
  multiValued = false
}
ResourceType_Product *-- Attribute_Product_title
class Attribute_Product_price {
  name = price
  type = NUMBER
  required = true
  multiValued = false
}
ResourceType_Product *-- Attribute_Product_price
class Attribute_Product_sku {
  name = sku
  type = TEXT
  required = false
  multiValued = false
}
ResourceType_Product *-- Attribute_Product_sku
class ResourceType_Order {
  name = Order
  supportsMedia = false
}
RefModel --> ResourceType_Order
class Attribute_Order_orderId {
  name = orderId
  type = TEXT
  required = true
  multiValued = false
}
ResourceType_Order *-- Attribute_Order_orderId
class Attribute_Order_total {
  name = total
  type = NUMBER
  required = true
  multiValued = false
}
ResourceType_Order *-- Attribute_Order_total

class ContextType_AmazonMarketplace {
  name = AmazonMarketplace
  kind = CATALOG
}
RefModel --> ContextType_AmazonMarketplace
ContextType_AmazonMarketplace --> ResourceType_Product : contains
ContextType_AmazonMarketplace --> ResourceType_Order : contains

ResourceType_Order --> ResourceType_Product : OrderForProduct ["1".."0..*"] recursive=false

class FeedbackType_Review {
  name = Review
  kind = REVIEW
  subjectScope = RESOURCE_ONLY
  hasRating = true
  recursive = false
  allowsMedia = false
}
RefModel --> FeedbackType_Review
class FeedbackType_Comment {
  name = Comment
  kind = COMMENT
  subjectScope = RESOURCE_OR_FEEDBACK
  hasRating = false
  recursive = true
  allowsMedia = false
}
RefModel --> FeedbackType_Comment

class FeedbackDefinition_ProductReview {
  name = ProductReview
  requiresVerifiedContext = true
  uniquePerAuthorTarget = true
}
RefModel --> FeedbackDefinition_ProductReview
FeedbackDefinition_ProductReview --> FeedbackType_Review : type
FeedbackDefinition_ProductReview --> UserType_Buyer : author
FeedbackDefinition_ProductReview --> ResourceType_Product : subjectResource
class FeedbackPolicy_ProductReview {
  status = ENABLED
}
FeedbackDefinition_ProductReview *-- FeedbackPolicy_ProductReview
class RatingPolicy_ProductReview {
  min = 1.0
  max = 5.0
  step = 1.0
  scale = NUMERIC
}
FeedbackDefinition_ProductReview *-- RatingPolicy_ProductReview
class FeedbackDefinition_ProductComment {
  name = ProductComment
  requiresVerifiedContext = false
  uniquePerAuthorTarget = false
}
RefModel --> FeedbackDefinition_ProductComment
FeedbackDefinition_ProductComment --> FeedbackType_Comment : type
FeedbackDefinition_ProductComment --> UserType_Buyer : author
FeedbackDefinition_ProductComment --> ResourceType_Product : subjectResource
FeedbackDefinition_ProductComment --> FeedbackDefinition_ProductReview : parent
class FeedbackPolicy_ProductComment {
  status = ENABLED
}
FeedbackDefinition_ProductComment *-- FeedbackPolicy_ProductComment

class ValidationRule_AmazonValidation {
  name = AmazonValidation
  kind = MANUAL
  severity = WARNING
  expression = "payload != null"
  implementationId = val01
}
RefModel --> ValidationRule_AmazonValidation
ValidationRule_AmazonValidation --> ResourceType_Product : appliesToResource
ValidationRule_AmazonValidation --> FeedbackDefinition_ProductReview : appliesToFeedback

class AuthorizationRule_READ_Buyer {
  allowedAction = READ
}
RefModel --> AuthorizationRule_READ_Buyer
AuthorizationRule_READ_Buyer --> UserType_Buyer : actor
AuthorizationRule_READ_Buyer --> ResourceType_Product : resourceTarget
AuthorizationRule_READ_Buyer --> FeedbackDefinition_ProductReview : feedbackTarget
AuthorizationRule_READ_Buyer --> ContextType_AmazonMarketplace : context

class ModerationPolicy_ReviewModeration {
  name = ReviewModeration
  mode = MANUAL
  trigger = "onReport"
  decision = FLAGGED
}
RefModel --> ModerationPolicy_ReviewModeration
ModerationPolicy_ReviewModeration --> ResourceType_Product : monitorsResource
ModerationPolicy_ReviewModeration --> FeedbackDefinition_ProductReview : monitorsFeedback
ModerationPolicy_ReviewModeration --> UserType_Moderator : executedBy
ModerationPolicy_ReviewModeration --> ContextType_AmazonMarketplace : inContext

class AutomationRule_AmazonAutoValidate {
  name = AmazonAutoValidate
  trigger = "onCreate"
  condition = "true"
  action = "run validations"
}
RefModel --> AutomationRule_AmazonAutoValidate
AutomationRule_AmazonAutoValidate --> ResourceType_Product : context
AutomationRule_AmazonAutoValidate --> ContextType_AmazonMarketplace : inContext
AutomationRule_AmazonAutoValidate --> FeedbackDefinition_ProductReview : onFeedback
AutomationRule_AmazonAutoValidate --> ValidationRule_AmazonValidation : uses

class VerificationPolicy_ProductReviewVerification {
  name = ProductReviewVerification
  mode = MANUAL
  appliesWhen = "onCreate"
}
RefModel --> VerificationPolicy_ProductReviewVerification
VerificationPolicy_ProductReviewVerification --> FeedbackDefinition_ProductReview : verifies

@enduml

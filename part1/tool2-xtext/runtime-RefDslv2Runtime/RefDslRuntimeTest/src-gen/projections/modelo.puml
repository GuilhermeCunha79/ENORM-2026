@startuml
title REF Model - Marketplace
skinparam classAttributeIconSize 0

class RefModel {
  name = Marketplace
  version = "1.0.0"
}

class UserType_Buyer {
  name = Buyer
  kind = BUYER
}
RefModel --> UserType_Buyer
class UserType_Seller {
  name = Seller
  kind = SELLER
}
RefModel --> UserType_Seller
class UserType_Moderator {
  name = Moderator
  kind = MODERATOR
}
RefModel --> UserType_Moderator
class UserType_TrustedBuyer {
  name = TrustedBuyer
  kind = BUYER
}
RefModel --> UserType_TrustedBuyer
UserType_TrustedBuyer --|> UserType_Buyer

class ResourceType_Product {
  name = Product
  supportsMedia = true
}
RefModel --> ResourceType_Product
class Attribute_Product_title {
  name = title
  type = TEXT
  required = true
  multiValued = false
}
ResourceType_Product *-- Attribute_Product_title
class Attribute_Product_price {
  name = price
  type = NUMBER
  required = true
  multiValued = false
}
ResourceType_Product *-- Attribute_Product_price
class Attribute_Product_publishedAt {
  name = publishedAt
  type = DATETIME
  required = false
  multiValued = false
}
ResourceType_Product *-- Attribute_Product_publishedAt
class ResourceType_Category {
  name = Category
  supportsMedia = false
}
RefModel --> ResourceType_Category
class Attribute_Category_categoryName {
  name = categoryName
  type = TEXT
  required = true
  multiValued = false
}
ResourceType_Category *-- Attribute_Category_categoryName

class ContextType_Shop {
  name = Shop
  kind = CATALOG
}
RefModel --> ContextType_Shop
ContextType_Shop --> ResourceType_Product : contains
ContextType_Shop --> ResourceType_Category : contains

ResourceType_Product --> ResourceType_Category : ProductInCategory ["0..*".."1"] recursive=false

class FeedbackType_Review {
  name = Review
  kind = REVIEW
  subjectScope = RESOURCE_ONLY
  hasRating = true
  recursive = false
  allowsMedia = false
}
RefModel --> FeedbackType_Review
class FeedbackType_Comment {
  name = Comment
  kind = COMMENT
  subjectScope = RESOURCE_OR_FEEDBACK
  hasRating = false
  recursive = true
  allowsMedia = false
}
RefModel --> FeedbackType_Comment

class FeedbackDefinition_ProductReview {
  name = ProductReview
  requiresVerifiedContext = true
  uniquePerAuthorTarget = true
}
RefModel --> FeedbackDefinition_ProductReview
FeedbackDefinition_ProductReview --> FeedbackType_Review : type
FeedbackDefinition_ProductReview --> UserType_Buyer : author
FeedbackDefinition_ProductReview --> ResourceType_Product : subjectResource
class FeedbackPolicy_ProductReview {
  status = ENABLED
}
FeedbackDefinition_ProductReview *-- FeedbackPolicy_ProductReview
class RatingPolicy_ProductReview {
  min = 1.0
  max = 5.0
  step = 1.0
  scale = NUMERIC
}
FeedbackDefinition_ProductReview *-- RatingPolicy_ProductReview
class FeedbackDefinition_ProductComment {
  name = ProductComment
  requiresVerifiedContext = false
  uniquePerAuthorTarget = false
}
RefModel --> FeedbackDefinition_ProductComment
FeedbackDefinition_ProductComment --> FeedbackType_Comment : type
FeedbackDefinition_ProductComment --> UserType_Seller : author
FeedbackDefinition_ProductComment --> ResourceType_Product : subjectResource
FeedbackDefinition_ProductComment --> FeedbackDefinition_ProductReview : parent
class FeedbackPolicy_ProductComment {
  status = ENABLED
}
FeedbackDefinition_ProductComment *-- FeedbackPolicy_ProductComment

class ValidationRule_BasicValidation {
  name = BasicValidation
  kind = MANUAL
  severity = WARNING
  expression = "payload != null"
  implementationId = val01
}
RefModel --> ValidationRule_BasicValidation
ValidationRule_BasicValidation --> ResourceType_Product : appliesToResource
ValidationRule_BasicValidation --> FeedbackDefinition_ProductReview : appliesToFeedback

class AuthorizationRule_READ_Buyer {
  allowedAction = READ
}
RefModel --> AuthorizationRule_READ_Buyer
AuthorizationRule_READ_Buyer --> UserType_Buyer : actor
AuthorizationRule_READ_Buyer --> ResourceType_Product : resourceTarget
AuthorizationRule_READ_Buyer --> FeedbackDefinition_ProductReview : feedbackTarget
AuthorizationRule_READ_Buyer --> ContextType_Shop : context

class ModerationPolicy_ReviewModeration {
  name = ReviewModeration
  mode = MANUAL
  trigger = "onReport"
  decision = FLAGGED
}
RefModel --> ModerationPolicy_ReviewModeration
ModerationPolicy_ReviewModeration --> ResourceType_Product : monitorsResource
ModerationPolicy_ReviewModeration --> FeedbackDefinition_ProductReview : monitorsFeedback
ModerationPolicy_ReviewModeration --> UserType_Moderator : executedBy
ModerationPolicy_ReviewModeration --> ContextType_Shop : inContext

class AutomationRule_AutoValidate {
  name = AutoValidate
  trigger = "onCreate"
  condition = "true"
  action = "run validations"
}
RefModel --> AutomationRule_AutoValidate
AutomationRule_AutoValidate --> ResourceType_Product : context
AutomationRule_AutoValidate --> ContextType_Shop : inContext
AutomationRule_AutoValidate --> FeedbackDefinition_ProductReview : onFeedback
AutomationRule_AutoValidate --> ValidationRule_BasicValidation : uses

class VerificationPolicy_ReviewVerification {
  name = ReviewVerification
  mode = MANUAL
  appliesWhen = "onCreate"
}
RefModel --> VerificationPolicy_ReviewVerification
VerificationPolicy_ReviewVerification --> FeedbackDefinition_ProductReview : verifies

@enduml

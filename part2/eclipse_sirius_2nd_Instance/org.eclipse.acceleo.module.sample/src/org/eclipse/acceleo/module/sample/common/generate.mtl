[file (domainEnumsPath(m) + '/ActionKind.java', false, 'UTF-8')]package [domainEnumsPackage(m)/]; public enum ActionKind { READ, CREATE, UPDATE, DELETE, COMMENT, RATE, VOTE, REPORT, SUBSCRIBE, MODERATE, VALIDATE }[/file]
[file (domainEnumsPath(m) + '/ModerationMode.java', false, 'UTF-8')]package [domainEnumsPackage(m)/]; public enum ModerationMode { AUTOMATIC, MANUAL, HYBRID }[/file]
[file (domainEnumsPath(m) + '/ModerationDecision.java', false, 'UTF-8')]package [domainEnumsPackage(m)/]; public enum ModerationDecision { APPROVED, FLAGGED, HIDDEN, REMOVED, BLOCKED, REJECTED }[/file]
[file (domainEnumsPath(m) + '/TriggerEvent.java', false, 'UTF-8')]package [domainEnumsPackage(m)/]; public enum TriggerEvent { ON_RESOURCE_CREATE, ON_RESOURCE_UPDATE, ON_RESOURCE_DELETE, ON_FEEDBACK_CREATE, ON_FEEDBACK_UPDATE, ON_FEEDBACK_DELETE, ON_REPORT_SUBMITTED, ON_REPORT_THRESHOLD, ON_MANUAL_REQUEST }[/file]
[file (domainEnumsPath(m) + '/SortCriterion.java', false, 'UTF-8')]package [domainEnumsPackage(m)/]; public enum SortCriterion { DATE, VALUE, RELEVANCE }[/file]

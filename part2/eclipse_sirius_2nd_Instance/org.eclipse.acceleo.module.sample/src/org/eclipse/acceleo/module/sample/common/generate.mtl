[template public generateJpaConverters(m : RefModel)]
[file (domainRootPath(m) + '/UriAttributeConverter.java', false, 'UTF-8')]
package [domainPackage(m)/];

import jakarta.persistence.AttributeConverter;
import jakarta.persistence.Converter;
import java.net.URI;

@Converter(autoApply = true)
public class UriAttributeConverter implements AttributeConverter<URI, String> {
    @Override
    public String convertToDatabaseColumn(URI attribute) {
        return attribute == null ? null : attribute.toString();
    }

    @Override
    public URI convertToEntityAttribute(String dbData) {
        return dbData == null ? null : URI.create(dbData);
    }
}
[/file]
[/template]


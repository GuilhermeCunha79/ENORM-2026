            [for (d : FeedbackDefinition | m.feedbackDefinitions) separator(',\n            ')]new FeedbackDefinitionSpec(
                "[d.name/]",
                [d.requiresVerifiedContext/],
                "[d.verificationRequirement/]",
                [d.uniquePerAuthorTarget/],
                "[d.type.name/]",
                [qResource(d.subjectResource)/],
                "[d.author.name/]",
                [qFeedback(d.subjectFeedback)/]",
                [if (d.policy.oclIsUndefined())]null[else]"[d.policy.status/]"[/if],
                [if (d.rating.oclIsUndefined())]null[else]"[d.rating.minValue/]"[/if],
                [if (d.rating.oclIsUndefined())]null[else]"[d.rating.maxValue/]"[/if],
                [if (d.rating.oclIsUndefined())]null[else]"[d.rating.step/]"[/if]
            )[/for]

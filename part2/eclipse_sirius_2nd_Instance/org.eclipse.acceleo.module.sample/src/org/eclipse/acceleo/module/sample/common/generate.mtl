[template public generateModelViews(m : RefModel)]
[file (rootPath(m) + '/model/Resources.java', false, 'UTF-8')]
package [basePackage(m)/].model;

import java.util.List;

public final class Resources {
    private Resources() {
    }

[for (rt : ResourceType | m.resourceTypes)]
    public record [rt.name/]Spec(String type, boolean supportsMedia, List<String> superTypes, String restPath) {}
[/for]

    public static List<Object> all() {
        return List.of(
[for (rt : ResourceType | m.resourceTypes) separator(',\n')]
                new [rt.name/]Spec("[rt.name/]", [rt.supportsMedia/], List.of([for (st : ResourceType | rt.superTypes) separator(', ')]"[st.name/]"[/for]), "/api/[resourcePath(rt)/]")[/for]
        );
    }
}
[/file]

[file (rootPath(m) + '/model/Feedback.java', false, 'UTF-8')]
package [basePackage(m)/].model;

import java.util.List;

public final class Feedback {
    private Feedback() {
    }

    public record FeedbackTypeSpec(String name, String kind, String subjectScope, boolean hasRating, boolean recursive, boolean allowsText, boolean allowsMedia, String polarity) {}
    public record FeedbackDefinitionSpec(String name, boolean requiresVerifiedContext, String verificationRequirement, boolean uniquePerAuthorTarget, String targetKind, String targetName, String endpoint) {}

    public static List<FeedbackTypeSpec> types() {
        return List.of(
[for (t : FeedbackType | m.feedbackTypes) separator(',\n')]
                new FeedbackTypeSpec("[t.name/]", "[t.kind/]", "[t.subjectScope/]", [t.hasRating/], [t.recursive/], [t.allowsText/], [t.allowsMedia/], "[t.polarity/]")[/for]
        );
    }

    public static List<FeedbackDefinitionSpec> definitions() {
        return List.of(
[for (d : FeedbackDefinition | m.feedbackDefinitions) separator(',\n')]
                new FeedbackDefinitionSpec("[d.name/]", [d.requiresVerifiedContext/], "[d.verificationRequirement/]", [d.uniquePerAuthorTarget/], "[feedbackTargetKind(d)/]", "[feedbackTargetName(d)/]", "/api/feedback/[d.name.toLowerFirst()/]")[/for]
        );
    }
}
[/file]
[/template]

[template public generateGovernance(m : RefModel)]
[file (rootPath(m) + '/governance/' + baseName(m) + 'Governance.java', false, 'UTF-8')]
package [basePackage(m)/].governance;

import java.util.List;

public final class [baseName(m)/]Governance {
    private [baseName(m)/]Governance() {
    }

    public record AuthorizationSpec(String name, String action, String actor, String context, String resourceTarget, String feedbackTarget) {}
    public record ValidationSpec(String name, String kind, String severity, String appliesToResource, String appliesToFeedback) {}
    public record ModerationPolicySpec(String name, String mode, String trigger, String decision, String monitorsResource, String monitorsFeedback) {}
    public record VerificationPolicySpec(String name, String mode, String appliesWhen, String verifies) {}
    public record SortingPolicySpec(String name, String criterion, String direction, String appliesToResource, String appliesToFeedback, String inContext) {}

    public static List<AuthorizationSpec> authorizations() {
        return List.of(
[for (a : AuthorizationRule | m.authorizationRules) separator(',\n')]
                new AuthorizationSpec("[a.name/]", "[a.allowedAction/]", "[a.actor.name/]", [qAuthorizationContext(a)/], "[a.resourceTarget.name/]", [qFeedback(a.feedbackTarget)/])[/for]
        );
    }

    public static List<ValidationSpec> validations() {
        return List.of(
[for (v : ValidationRule | m.validationRules) separator(',\n')]
                new ValidationSpec("[v.name/]", "[v.kind/]", "[v.severity/]", [qResource(v.appliesToResource)/], [qFeedback(v.appliesToFeedback)/])[/for]
        );
    }

    public static List<ModerationPolicySpec> moderationPolicies() {
        return List.of(
[for (p : ModerationPolicy | m.moderationPolicies) separator(',\n')]
                new ModerationPolicySpec("[p.name/]", "[p.mode/]", "[p.trigger/]", "[p.decision/]", [qResource(p.monitorsResource)/], [qFeedback(p.monitorsFeedback)/])[/for]
        );
    }

    public static List<VerificationPolicySpec> verificationPolicies() {
        return List.of(
[for (v : VerificationPolicy | m.verificationPolicies) separator(',\n')]
                new VerificationPolicySpec("[v.name/]", "[v.mode/]", "[v.appliesWhen/]", "[v.verifies.name/]")[/for]
        );
    }

    public static List<SortingPolicySpec> sortingPolicies() {
        return List.of(
[for (s : SortingPolicy | m.sortingPolicies) separator(',\n')]
                new SortingPolicySpec("[s.name/]", "[s.criterion/]", "[s.direction/]", [qResource(s.appliesToResource)/], [qFeedback(s.appliesToFeedback)/], [qContext(s.inContext)/])[/for]
        );
    }
}
[/file]
[/template]


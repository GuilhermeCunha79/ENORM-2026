[comment encoding = UTF-8 /]
[module generate('http://www.example.org/enorm')/]

[query public baseName(m : RefModel) : String = m.name /]
[query public pkg(m : RefModel) : String = m.name.toLowerFirst() /]
[query public rootPath(m : RefModel) : String = 'src/generated/' + pkg(m) /]
[query public basePackage(m : RefModel) : String = 'generated.' + pkg(m) /]
[query public apiPackage(m : RefModel) : String = basePackage(m) + '.api' /]
[query public dtoPackage(m : RefModel) : String = basePackage(m) + '.dto' /]
[query public servicePackage(m : RefModel) : String = basePackage(m) + '.service' /]
[query public repositoryPackage(m : RefModel) : String = basePackage(m) + '.repository' /]
[query public domainPackage(m : RefModel) : String = basePackage(m) + '.domain' /]
[query public domainGeneratedPackage(m : RefModel) : String = domainPackage(m) + '.generated' /]
[query public domainEnumsPackage(m : RefModel) : String = domainPackage(m) + '.enums' /]
[query public domainRootPath(m : RefModel) : String = rootPath(m) + '/domain' /]
[query public domainGeneratedPath(m : RefModel) : String = domainRootPath(m) + '/generated' /]
[query public domainEnumsPath(m : RefModel) : String = domainRootPath(m) + '/enums' /]

[query public isMany(card : String) : Boolean = card = '*' or card = '0..*' or card = '1..*' /]
[query public shouldSkipAttribute(a : Attribute) : Boolean = a.name = 'id' or a.name = 'Id' /]
[query public baseJavaType(p : PrimitiveType) : String = if p = PrimitiveType::TEXT then 'String' else if p = PrimitiveType::NUMBER then 'Double' else if p = PrimitiveType::BOOLEAN then 'Boolean' else if p = PrimitiveType::DATE then 'LocalDate' else if p = PrimitiveType::DATETIME then 'LocalDateTime' else if p = PrimitiveType::URL then 'URI' else 'String' endif endif endif endif endif endif /]
[query public javaType(p : PrimitiveType, multi : Boolean) : String = if multi then 'List<' + baseJavaType(p) + '>' else baseJavaType(p) endif /]
[query public qText(s : String) : String = if s.oclIsUndefined() then 'null' else '"' + s + '"' endif /]
[query public qResource(r : ResourceType) : String = if r.oclIsUndefined() then 'null' else '"' + r.name + '"' endif /]
[query public qFeedback(f : FeedbackDefinition) : String = if f.oclIsUndefined() then 'null' else '"' + f.name + '"' endif /]
[query public qContext(c : ContextType) : String = if c.oclIsUndefined() then 'null' else '"' + c.name + '"' endif /]
[query public resourcePath(rt : ResourceType) : String = rt.name.toLowerFirst() + 's' /]
[query public relationEndpoint(r : ResourceRelation) : String = r.name.toLowerFirst() /]
[query public relationField(r : ResourceRelation) : String = if r.recursive then 'children' else r.target.name.toLowerFirst() + (if isMany(r.targetCardinality) then 's' else '' endif) endif /]
[query public runtimeProfile(m : RefModel) : String = if m.name = 'Amazon' then 'catalog-commerce' else if m.name = 'Reddit' then 'community-discussion' else if m.name = 'YouTube' then 'media-feedback' else 'generic-feedback' endif endif endif /]
[query public scenarioSummary(m : RefModel) : String = if m.name = 'YouTube' then 'Evaluated resources are videos; users comment videos, react with like/dislike, comments may thread, comments can be reported, and comments are commonly sorted by date or value.' else if m.name = 'Amazon' then 'Evaluated resources are bought products; users evaluate products with a five-star scale, text, optional photos/videos, and a verification process that may be manual or automatic.' else if m.name = 'Reddit' then 'Users post in topic forums, reply in threads, upvote/downvote posts and comments, report posts and comments, and each topic has rules, moderators, and automation support.' else 'Generated feedback REST API.' endif endif endif /]
[query public feedbackTargetKind(d : FeedbackDefinition) : String = if not d.subjectResource.oclIsUndefined() then 'RESOURCE' else if not d.subjectFeedback.oclIsUndefined() then 'FEEDBACK' else 'NONE' endif endif /]
[query public feedbackTargetName(d : FeedbackDefinition) : String = if not d.subjectResource.oclIsUndefined() then d.subjectResource.name else if not d.subjectFeedback.oclIsUndefined() then d.subjectFeedback.name else '' endif endif /]
[query public constName(s : String) : String = s.toUpper().replaceAll('[^A-Z0-9]+', '_') /]

[template public generateElement(m : RefModel)]
[comment @main/]
[generateApplication(m)/]
[generateReadme(m)/]
[generateModelViews(m)/]
[generateGovernance(m)/]
[generateRuleBodies(m)/]
[generateDomain(m)/]
[for (rt : ResourceType | m.resourceTypes)]
[generateDto(m, rt)/]
[generateRepository(m, rt)/]
[generateService(m, rt)/]
[generateController(m, rt)/]
[generateDomainResource(m, rt)/]
[/for]
[/template]

[template public generateApplication(m : RefModel)]
[file (rootPath(m) + '/' + baseName(m) + 'Application.java', false, 'UTF-8')]
package [basePackage(m)/];

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;

@SpringBootApplication
public class [baseName(m)/]Application {

    public static final String MODEL_NAME = "[m.name/]";
    public static final String MODEL_VERSION = "[m.version/]";
    public static final String RUNTIME_PROFILE = "[runtimeProfile(m)/]";

    public static void main(String args) {
        SpringApplication.run([baseName(m)/]Application.class, args);
    }
}
[/file]
[/template]

[template public generateReadme(m : RefModel)]
[file (rootPath(m) + '/README-REST.txt', false, 'UTF-8')]
REF-generated REST backend scaffold
Model: [m.name/] [m.version/]
Profile: [runtimeProfile(m)/]

Scope restriction:
This generator must only expose behavior that is explicitly present in the provided domain model and REF scenario text.
No extra platform behavior should be inferred beyond those artifacts.

Scenario summary:
[scenarioSummary(m)/]

Generated endpoints:
[for (rt : ResourceType | m.resourceTypes)]- /api/[resourcePath(rt)/]
[/for]
[/file]
[/template]

[template public generateModelViews(m : RefModel)]
[file (rootPath(m) + '/model/Resources.java', false, 'UTF-8')]
package [basePackage(m)/].model;

import java.util.List;

public final class Resources {
    private Resources() {
    }

[for (rt : ResourceType | m.resourceTypes)]
    public record [rt.name/]Spec(String type, boolean supportsMedia, List<String> superTypes, String restPath) {}
[/for]

    public static List<Object> all() {
        return List.of(
[for (rt : ResourceType | m.resourceTypes) separator(',\n')]
                new [rt.name/]Spec("[rt.name/]", [rt.supportsMedia/], List.of([for (st : ResourceType | rt.superTypes) separator(', ')]"[st.name/]"[/for]), "/api/[resourcePath(rt)/]")[/for]
        );
    }
}
[/file]

[file (rootPath(m) + '/model/Feedback.java', false, 'UTF-8')]
package [basePackage(m)/].model;

import java.util.List;

public final class Feedback {
    private Feedback() {
    }

    public record FeedbackTypeSpec(String name, String kind, String subjectScope, boolean hasRating, boolean recursive, boolean allowsText, boolean allowsMedia, String polarity) {}
    public record FeedbackDefinitionSpec(String name, boolean requiresVerifiedContext, String verificationRequirement, boolean uniquePerAuthorTarget, String targetKind, String targetName, String endpoint) {}

    public static List<FeedbackTypeSpec> types() {
        return List.of(
[for (t : FeedbackType | m.feedbackTypes) separator(',\n')]
                new FeedbackTypeSpec("[t.name/]", "[t.kind/]", "[t.subjectScope/]", [t.hasRating/], [t.recursive/], [t.allowsText/], [t.allowsMedia/], "[t.polarity/]")[/for]
        );
    }

    public static List<FeedbackDefinitionSpec> definitions() {
        return List.of(
[for (d : FeedbackDefinition | m.feedbackDefinitions) separator(',\n')]
                new FeedbackDefinitionSpec("[d.name/]", [d.requiresVerifiedContext/], "[d.verificationRequirement/]", [d.uniquePerAuthorTarget/], "[feedbackTargetKind(d)/]", "[feedbackTargetName(d)/]", "/api/feedback/[d.name.toLowerFirst()/]")[/for]
        );
    }
}
[/file]
[/template]

[template public generateGovernance(m : RefModel)]
[file (rootPath(m) + '/governance/' + baseName(m) + 'Governance.java', false, 'UTF-8')]
package [basePackage(m)/].governance;

import java.util.List;

public final class [baseName(m)/]Governance {
    private [baseName(m)/]Governance() {
    }

    public record AuthorizationSpec(String name, String action, String actor, String context, String resourceTarget, String feedbackTarget) {}
    public record ValidationSpec(String name, String kind, String severity, String appliesToResource, String appliesToFeedback) {}
    public record ModerationPolicySpec(String name, String mode, String trigger, String decision, String monitorsResource, String monitorsFeedback) {}
    public record VerificationPolicySpec(String name, String mode, String appliesWhen, String verifies) {}
    public record SortingPolicySpec(String name, String criterion, String direction, String appliesToResource, String appliesToFeedback, String inContext) {}

    public static List<AuthorizationSpec> authorizations() {
        return List.of(
[for (a : AuthorizationRule | m.authorizationRules) separator(',\n')]
                new AuthorizationSpec("[a.name/]", "[a.allowedAction/]", "[a.actor.name/]", [qContext(a.context)/], "[a.resourceTarget.name/]", [qFeedback(a.feedbackTarget)/])[/for]
        );
    }

    public static List<ValidationSpec> validations() {
        return List.of(
[for (v : ValidationRule | m.validationRules) separator(',\n')]
                new ValidationSpec("[v.name/]", "[v.kind/]", "[v.severity/]", [qResource(v.appliesToResource)/], [qFeedback(v.appliesToFeedback)/])[/for]
        );
    }

    public static List<ModerationPolicySpec> moderationPolicies() {
        return List.of(
[for (p : ModerationPolicy | m.moderationPolicies) separator(',\n')]
                new ModerationPolicySpec("[p.name/]", "[p.mode/]", "[p.trigger/]", "[p.decision/]", [qResource(p.monitorsResource)/], [qFeedback(p.monitorsFeedback)/])[/for]
        );
    }

    public static List<VerificationPolicySpec> verificationPolicies() {
        return List.of(
[for (v : VerificationPolicy | m.verificationPolicies) separator(',\n')]
                new VerificationPolicySpec("[v.name/]", "[v.mode/]", "[v.appliesWhen/]", "[v.verifies.name/]")[/for]
        );
    }

    public static List<SortingPolicySpec> sortingPolicies() {
        return List.of(
[for (s : SortingPolicy | m.sortingPolicies) separator(',\n')]
                new SortingPolicySpec("[s.name/]", "[s.criterion/]", "[s.direction/]", [qResource(s.appliesToResource)/], [qFeedback(s.appliesToFeedback)/], [qContext(s.inContext)/])[/for]
        );
    }
}
[/file]
[/template]

[template public generateRuleBodies(m : RefModel)]
[file (rootPath(m) + '/runtime/RuleBodies.java', false, 'UTF-8')]
package [basePackage(m)/].runtime;

public final class RuleBodies {
    private RuleBodies() {
    }

[for (v : ValidationRule | m.validationRules)]
    public static final String [constName(v.name)/]_EXPRESSION = [qText(v.expression)/];
    public static final String [constName(v.name)/]_IMPLEMENTATION = [qText(v.implementationId)/];
[/for]
}
[/file]
[/template]


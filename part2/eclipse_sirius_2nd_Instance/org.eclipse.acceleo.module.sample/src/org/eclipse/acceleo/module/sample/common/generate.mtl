[template public generateGovernance(m : RefModel)]
[file (rootPath(m).concat('/governance/').concat(baseName(m)).concat('Governance.java'), false, 'UTF-8')]
package generated.[pkg(m)/].governance;

import java.util.List;

public final class [baseName(m)/]Governance {

    public record AuthorizationSpec(
        String name,
        String allowedAction,
        String actor,
        String context,
        String resourceTarget,
        String feedbackTarget
    ) {}

    public record ValidationSpec(
        String name,
        String kind,
        String severity,
        String expression,
        String implementationBody,
        String appliesToResource,
        String appliesToFeedback,
        String invokedBy
    ) {}

    public record ModerationPolicySpec(
        String name,
        String mode,
        String trigger,
        String decision,
        String monitorsResource,
        String monitorsFeedback,
        List<String> executedBy,
        String inContext
    ) {}

    public record ConditionSpec(
        String name,
        String operator,
        String attribute,
        List<String> values
    ) {}

    public record ActionSpec(
        String name,
        String kind,
        String implementationBody
    ) {}

    public record AutomationSpec(
        String name,
        String trigger,
        String contextResource,
        String inContext,
        String onFeedback,
        String usesValidation,
        List<ConditionSpec> conditions,
        List<ActionSpec> actions
    ) {}

    public record VerificationPolicySpec(
        String name,
        String mode,
        String appliesWhen,
        String verifies
    ) {}

    public record SortingPolicySpec(
        String name,
        String criterion,
        String direction,
        String appliesToResource,
        String appliesToFeedback,
        String inContext
    ) {}

    public List<AuthorizationSpec> authorizations() {
        return List.of(
            [for (a : AuthorizationRule | m.authorizationRules) separator(',\n            ')]new AuthorizationSpec(
                "[a.name/]",
                "[a.allowedAction/]",
                "[a.actor.name/]",
                [qContext(a.eGet('context'))/],
                "[a.resourceTarget.name/]",
                [qFeedback(a.feedbackTarget)/]
            )[/for]
        );
    }

    public List<ValidationSpec> validations() {
        return List.of(
            [for (v : ValidationRule | m.validationRules) separator(',\n            ')]new ValidationSpec(
                "[v.name/]",
                "[v.kind/]",
                "[v.severity/]",
                """
[v.expression/]
                """,
                """
[v.implementationId/]
                """,
                [qResource(v.appliesToResource)/],
                [qFeedback(v.appliesToFeedback)/],
                [qAutomation(v.invokedBy)/]
            )[/for]
        );
    }

    public List<ModerationPolicySpec> moderationPolicies() {
        return List.of(
            [for (p : ModerationPolicy | m.moderationPolicies) separator(',\n            ')]new ModerationPolicySpec(
                "[p.name/]",
                "[p.mode/]",
                "[p.trigger/]",
                "[p.decision/]",
                [qResource(p.monitorsResource)/],
                [qFeedback(p.monitorsFeedback)/],
                List.of([for (u : UserType | p.executedBy) separator(', ')]"[u.name/]"[/for]),
                [qContext(p.inContext)/]
            )[/for]
        );
    }

    public List<AutomationSpec> automations() {
        return List.of(
            [for (a : AutomationRule | m.automationRules) separator(',\n            ')]new AutomationSpec(
                "[a.name/]",
                "[a.trigger/]",
                [qResource(a.eGet('context'))/],
                [qContext(a.inContext)/],
                [qFeedback(a.onFeedback)/],
                "[a.uses.name/]",
                List.of(
                    [for (c : Condition | a.conditions) separator(',\n                    ')]new ConditionSpec(
                        "[c.name/]",
                        "[c.operator/]",
                        "[c.attribute.name/]",
                        List.of([for (v : ConditionValue | c.children) separator(', ')]"[v.value/]"[/for])
                    )[/for]
                ),
                List.of(
                    [for (ac : Action | a.actions) separator(',\n                    ')]new ActionSpec(
                        "[ac.name/]",
                        "[ac.kind/]",
                        """
[ac.message/]
                        """
                    )[/for]
                )
            )[/for]
        );
    }

    public List<VerificationPolicySpec> verificationPolicies() {
        return List.of(
            [for (v : VerificationPolicy | m.verificationPolicies) separator(',\n            ')]new VerificationPolicySpec(
                "[v.name/]",
                "[v.mode/]",
                "[v.appliesWhen/]",
                "[v.verifies.name/]"
            )[/for]
        );
    }

    public List<SortingPolicySpec> sortingPolicies() {
        return List.of(
            [for (s : SortingPolicy | m.sortingPolicies) separator(',\n            ')]new SortingPolicySpec(
                "[s.name/]",
                "[s.criterion/]",
                "[s.direction/]",
                [qResource(s.appliesToResource)/],
                [qFeedback(s.appliesToFeedback)/],
                [qContext(s.inContext)/]
            )[/for]
        );
    }
}
[/file]
[/template]


[comment encoding = UTF-8 /]
[module generate('http://www.example.org/enorm')/]

[query public baseName(m : RefModel) : String = m.name /]
[query public pkg(m : RefModel) : String = m.name.toLowerFirst() /]
[query public rootPath(m : RefModel) : String = 'src/generated/' + pkg(m) /]
[query public basePackage(m : RefModel) : String = 'generated.' + pkg(m) /]
[query public domainPackage(m : RefModel) : String = basePackage(m) + '.domain' /]
[query public domainGeneratedPackage(m : RefModel) : String = domainPackage(m) + '.generated' /]
[query public domainEnumsPackage(m : RefModel) : String = domainPackage(m) + '.enums' /]
[query public domainRootPath(m : RefModel) : String = rootPath(m) + '/domain' /]
[query public domainGeneratedPath(m : RefModel) : String = domainRootPath(m) + '/generated' /]
[query public domainEnumsPath(m : RefModel) : String = domainRootPath(m) + '/enums' /]

[query public isOptional(card : String) : Boolean = card = '0..1' or card = '0..*' /]
[query public isMany(card : String) : Boolean = card = '*' or card = '0..*' or card = '1..*' /]
[query public shouldSkipAttribute(a : Attribute) : Boolean = a.name = 'id' or a.name = 'Id' /]
[query public fieldSuffix(r : ResourceRelation) : String = if isMany(r.targetCardinality) then 's' else '' endif /]
[query public relationSourceFieldName(r : ResourceRelation) : String = if r.recursive then if isMany(r.targetCardinality) then 'children' else 'child' endif else r.target.name.toLowerFirst() + fieldSuffix(r) endif /]
[query public relationTargetFieldName(r : ResourceRelation) : String = if r.recursive then 'parent' else r.source.name.toLowerFirst() endif /]

[query public baseJavaType(p : PrimitiveType) : String = if p = PrimitiveType::TEXT then 'String' else if p = PrimitiveType::NUMBER then 'Double' else if p = PrimitiveType::BOOLEAN then 'Boolean' else if p = PrimitiveType::DATE then 'LocalDate' else if p = PrimitiveType::DATETIME then 'LocalDateTime' else if p = PrimitiveType::URL then 'URI' else if p = PrimitiveType::IMAGE then 'String' else if p = PrimitiveType::VIDEO then 'String' else 'String' endif endif endif endif endif endif endif endif /]
[query public javaType(p : PrimitiveType, multi : Boolean) : String = if multi then 'List<' + baseJavaType(p) + '>' else baseJavaType(p) endif /]
[query public runtimeProfile(m : RefModel) : String = if m.name = 'Amazon' then 'catalog-commerce' else if m.name = 'Reddit' then 'community-platform' else if m.name = 'YouTube' then 'media-platform' else 'generic-platform' endif endif endif /]
[query public qResource(r : ResourceType) : String = if r.oclIsUndefined() then 'null' else '"' + r.name + '"' endif /]
[query public qContext(c : ContextType) : String = if c.oclIsUndefined() then 'null' else '"' + c.name + '"' endif /]
[query public qFeedback(f : FeedbackDefinition) : String = if f.oclIsUndefined() then 'null' else '"' + f.name + '"' endif /]
[query public qAutomation(a : AutomationRule) : String = if a.oclIsUndefined() then 'null' else '"' + a.name + '"' endif /]
[query public qText(s : String) : String = if s.oclIsUndefined() then 'null' else '"' + s + '"' endif /]
[query public feedbackTargetKind(d : FeedbackDefinition) : String = if not d.subjectResource.oclIsUndefined() then 'RESOURCE' else if not d.subjectFeedback.oclIsUndefined() then 'FEEDBACK' else 'NONE' endif endif /]
[query public feedbackTargetName(d : FeedbackDefinition) : String = if not d.subjectResource.oclIsUndefined() then d.subjectResource.name else if not d.subjectFeedback.oclIsUndefined() then d.subjectFeedback.name else '' endif endif /]
[query public constName(s : String) : String = s.toUpper() /]

[template public generateElement(m : RefModel)]
[comment @main/]
[generateApplication(m)/]
[generateUsers(m)/]
[generateResources(m)/]
[generateContexts(m)/]
[generateRelations(m)/]
[generateFeedback(m)/]
[generateGovernance(m)/]
[generateRuleBodies(m)/]
[generateDomain(m)/]
[/template]

[template public generateApplication(m : RefModel)]
[file (rootPath(m) + '/' + baseName(m) + 'Application.java', false, 'UTF-8')]
package generated.[pkg(m)/];

import generated.[pkg(m)/].governance.[baseName(m)/]Governance;

public final class [baseName(m)/]Application {
public static final String MODEL_NAME = "[baseName(m)/]";
public static final String MODEL_VERSION = "[m.version/]";
public static final String RUNTIME_PROFILE = "[runtimeProfile(m)/]";

private [baseName(m)/]Application() {
}

public static [baseName(m)/]Governance governance() {
return new [baseName(m)/]Governance();
}
}
[/file]
[/template]

[template public generateUsers(m : RefModel)]
[file (rootPath(m) + '/model/Users.java', false, 'UTF-8')]
package generated.[pkg(m)/].model;

import java.util.List;

public final class Users {
private Users() {
}

public record UserTypeSpec(String name, String kind, List<String> superTypes) {}

public static List<UserTypeSpec> all() {
return List.of(
[for (u : UserType | m.userTypes) separator(',')]
new UserTypeSpec("[u.name/]", "[u.kind/]", List.of([for (s : UserType | u.superTypes) separator(', ')]"[s.name/]"[/for]))
[/for]
);
}
}
[/file]
[/template]

[template public generateResources(m : RefModel)]
[file (rootPath(m) + '/model/Resources.java', false, 'UTF-8')]
package generated.[pkg(m)/].model;

import java.util.List;

public final class Resources {
private Resources() {
}

[for (rt : ResourceType | m.resourceTypes)]
public static final class [rt.name/] {
public static final String TYPE = "[rt.name/]";
public static final boolean SUPPORTS_MEDIA = [rt.supportsMedia/];
[if (rt.superTypes->notEmpty())]
public static final List<String> SUPER_TYPES = List.of([for (s : ResourceType | rt.superTypes) separator(', ')]"[s.name/]"[/for]);
[/if]
[for (a : Attribute | rt.attributes)]
private [javaType(a.type, a.multiValued)/] [a.name/];
[/for]
}
[/for]
}
[/file]
[/template]


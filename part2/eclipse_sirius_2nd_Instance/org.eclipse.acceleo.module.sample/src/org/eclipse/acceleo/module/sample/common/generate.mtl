package [servicePackage(m)/];

import [domainPackage(m)/].[rt.name/];
import [dtoPackage(m)/].[rt.name/]Dto;
import [repositoryPackage(m)/].[rt.name/]Repository;
import java.util.List;
import java.util.UUID;
import java.util.stream.Collectors;
import org.springframework.http.HttpStatus;
import org.springframework.stereotype.Service;
import org.springframework.web.server.ResponseStatusException;
[if (m.name = 'Amazon' and rt.name = 'ProductReview')]
import [dtoPackage(m)/].ProductReviewDto;
[/if]

@Service
public class [rt.name/]Service {
    private final [rt.name/]Repository repository;

    public [rt.name/]Service([rt.name/]Repository repository) {
        this.repository = repository;
    }

    public List<[rt.name/]Dto> list() {
        return repository.findAll().stream()
                .map(this::toDto)
                .collect(Collectors.toList());
    }

    public [rt.name/]Dto get(String id) {
        return repository.findById(id)
                .map(this::toDto)
                .orElseThrow(() -> new ResponseStatusException(HttpStatus.NOT_FOUND, "[rt.name/] not found"));
    }

    public [rt.name/]Dto create([rt.name/]Dto dto) {
[if (m.name = 'Amazon' and rt.name = 'ProductReview')]
        validateAmazonReview(dto);
[/if]
        [rt.name/] entity = toEntity(dto);
        if (entity.getId() == null || entity.getId().isBlank()) {
            entity.setId(UUID.randomUUID().toString());
        }
        return toDto(repository.save(entity));
    }

    public [rt.name/]Dto update(String id, [rt.name/]Dto dto) {
        [rt.name/] entity = repository.findById(id)
                .orElseThrow(() -> new ResponseStatusException(HttpStatus.NOT_FOUND, "[rt.name/] not found"));
[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))]
        entity.set[a.name.toUpperFirst()/](dto.[a.name/]());
[/for]
        return toDto(repository.save(entity));
    }

    public void delete(String id) {
        if (!repository.existsById(id)) {
            throw new ResponseStatusException(HttpStatus.NOT_FOUND, "[rt.name/] not found");
        }
        repository.deleteById(id);
    }

    private [rt.name/] toEntity([rt.name/]Dto dto) {
        [rt.name/] entity = new [rt.name/]();
        entity.setId(dto.id());
[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))]
        entity.set[a.name.toUpperFirst()/](dto.[a.name/]());
[/for]
        return entity;
    }

    private [rt.name/]Dto toDto([rt.name/] entity) {
        return new [rt.name/]Dto(entity.getId()[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))] , entity.get[a.name.toUpperFirst()/]()[/for]);
    }
[if (m.name = 'Amazon' and rt.name = 'ProductReview')]

    private void validateAmazonReview(ProductReviewDto dto) {
        if (dto.rating() == null || dto.rating() < 1.0 || dto.rating() > 5.0) {
            throw new ResponseStatusException(HttpStatus.BAD_REQUEST, "Rating must respect the 1..5 five-star scale");
        }
    }
[/if]
}

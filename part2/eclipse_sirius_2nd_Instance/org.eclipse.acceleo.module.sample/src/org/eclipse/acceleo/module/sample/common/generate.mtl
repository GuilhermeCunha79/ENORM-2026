package [domainGeneratedPackage(m)/];

import jakarta.persistence.Column;
import jakarta.persistence.ElementCollection;
import jakarta.persistence.Id;
import jakarta.persistence.MappedSuperclass;
import java.net.URI;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.List;

@MappedSuperclass
public abstract class Generated[rt.name/][if (rt.superTypes->notEmpty())] extends Generated[rt.superTypes->first().name/][/if] {
[if (rt.superTypes->isEmpty())]
    @Id
    @Column(name = "id", nullable = false, updatable = false)
    private String id;
[/if]
[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))]
[if (a.multiValued)]
    @ElementCollection
[/if]
    @Column(name = "[sqlColumnName(a.name)/]")
    private [javaType(a.type, a.multiValued)/] [a.name/][if (a.multiValued)] = new ArrayList<>()[/if];
[/for]

[if (rt.superTypes->isEmpty())]
    public String getId() {
        return id;
    }

    public void setId(String id) {
        this.id = id;
    }
[/if]
[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))]
    public [javaType(a.type, a.multiValued)/] get[a.name.toUpperFirst()/]() {
        return [a.name/];
    }

    public void set[a.name.toUpperFirst()/]([javaType(a.type, a.multiValued)/] [a.name/]) {
        this.[a.name/] = [a.name/];
    }
[/for]
}
[/file]
[/template]


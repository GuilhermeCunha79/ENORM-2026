[template public generateRepository(m : RefModel, rt : ResourceType)]
[file (rootPath(m) + '/repository/' + rt.name + 'Repository.java', false, 'UTF-8')]
package [repositoryPackage(m)/];

import [dtoPackage(m)/].[rt.name/]Dto;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.Optional;
import org.springframework.stereotype.Repository;

@Repository
public class [rt.name/]Repository {
    private final Map<String, [rt.name/]Dto> store = new LinkedHashMap<>();

    public List<[rt.name/]Dto> findAll() {
        return List.copyOf(store.values());
    }

    public Optional<[rt.name/]Dto> findById(String id) {
        return Optional.ofNullable(store.get(id));
    }

    public [rt.name/]Dto save([rt.name/]Dto dto) {
        store.put(dto.id(), dto);
        return dto;
    }

    public void delete(String id) {
        store.remove(id);
    }
}
[/file]
[/template]

[template public generateService(m : RefModel, rt : ResourceType)]
[file (rootPath(m) + '/service/' + rt.name + 'Service.java', false, 'UTF-8')]
package [servicePackage(m)/];

import [dtoPackage(m)/].[rt.name/]Dto;
import [repositoryPackage(m)/].[rt.name/]Repository;
import java.util.List;
import org.springframework.http.HttpStatus;
import org.springframework.stereotype.Service;
import org.springframework.web.server.ResponseStatusException;

@Service
public class [rt.name/]Service {
    private final [rt.name/]Repository repository;

    public [rt.name/]Service([rt.name/]Repository repository) {
        this.repository = repository;
    }

    public List<[rt.name/]Dto> list() {
        return repository.findAll();
    }

    public [rt.name/]Dto get(String id) {
        return repository.findById(id)
                .orElseThrow(() -> new ResponseStatusException(HttpStatus.NOT_FOUND, "[rt.name/] not found"));
    }

    public [rt.name/]Dto create([rt.name/]Dto dto) {
[if (m.name = 'Amazon' and rt.name = 'ProductReview')]
        validateAmazonReview(dto);
[/if]
        return repository.save(dto);
    }

    public [rt.name/]Dto update(String id, [rt.name/]Dto dto) {
        get(id);
        return repository.save(new [rt.name/]Dto(id[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))] , dto.[a.name/]()[/for]));
    }

    public void delete(String id) {
        get(id);
        repository.delete(id);
    }
[if (m.name = 'Amazon' and rt.name = 'ProductReview')]

    private void validateAmazonReview(ProductReviewDto dto) {
        if (dto.rating() == null || dto.rating() < 1.0 || dto.rating() > 5.0) {
            throw new ResponseStatusException(HttpStatus.BAD_REQUEST, "Rating must respect the 1..5 five-star scale");
        }
    }
[/if]
}
[/file]
[/template]

[template public generateController(m : RefModel, rt : ResourceType)]
[file (rootPath(m) + '/api/' + rt.name + 'Controller.java', false, 'UTF-8')]
package [apiPackage(m)/];

import [dtoPackage(m)/].[rt.name/]Dto;
import [servicePackage(m)/].[rt.name/]Service;
import java.util.List;
import org.springframework.http.HttpStatus;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.ResponseStatus;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/api/[resourcePath(rt)/]")
public class [rt.name/]Controller {
    private final [rt.name/]Service service;

    public [rt.name/]Controller([rt.name/]Service service) {
        this.service = service;
    }

    @GetMapping
    public List<[rt.name/]Dto> list() {
        return service.list();
    }

    @GetMapping("/{id}")
    public [rt.name/]Dto get(@PathVariable String id) {
        return service.get(id);
    }

    @PostMapping
    @ResponseStatus(HttpStatus.CREATED)
    public [rt.name/]Dto create(@RequestBody [rt.name/]Dto dto) {
        return service.create(dto);
    }

    @PutMapping("/{id}")
    public [rt.name/]Dto update(@PathVariable String id, @RequestBody [rt.name/]Dto dto) {
        return service.update(id, dto);
    }

    @DeleteMapping("/{id}")
    @ResponseStatus(HttpStatus.NO_CONTENT)
    public void delete(@PathVariable String id) {
        service.delete(id);
    }
[for (r : ResourceRelation | m.resourceRelations->select(r | r.source = rt))]

    @GetMapping("/{id}/[relationEndpoint(r)/]")
    public String [relationField(r)/](@PathVariable String id) {
        service.get(id);
        return "Generated relation endpoint for [r.name/]";
    }
[/for]
[if (m.name = 'YouTube' and rt.name = 'Video')]

    @PostMapping("/{id}/comments")
    public String commentOnVideo(@PathVariable String id) {
        service.get(id);
        return "Create comment on video";
    }

    @PostMapping("/{id}/likes")
    public String reactToVideo(@PathVariable String id) {
        service.get(id);
        return "Like or dislike video";
    }
[/if]
[if (m.name = 'YouTube' and rt.name = 'Comment')]

    @PostMapping("/{id}/replies")
    public String replyToComment(@PathVariable String id) {
        service.get(id);
        return "Reply to comment thread";
    }

    @PostMapping("/{id}/reports")
    public String reportComment(@PathVariable String id) {
        service.get(id);
        return "Report comment";
    }
[/if]
[if (m.name = 'Amazon' and rt.name = 'Product')]

    @PostMapping("/{id}/reviews")
    public String reviewProduct(@PathVariable String id) {
        service.get(id);
        return "Create product review";
    }
[/if]
[if (m.name = 'Amazon' and rt.name = 'ProductReview')]

    @PostMapping("/{id}/votes")
    public String helpfulVote(@PathVariable String id) {
        service.get(id);
        return "Vote review as helpful or not helpful";
    }

    @PostMapping("/{id}/verification")
    public String verifyReview(@PathVariable String id) {
        service.get(id);
        return "Start or update review verification process";
    }
[/if]
[if (m.name = 'Reddit' and rt.name = 'Subreddit')]

    @PostMapping("/{id}/posts")
    public String createPost(@PathVariable String id) {
        service.get(id);
        return "Create post in subreddit";
    }
[/if]
[if (m.name = 'Reddit' and (rt.name = 'Post' or rt.name = 'Comment'))]

    @PostMapping("/{id}/votes")
    public String vote(@PathVariable String id) {
        service.get(id);
        return "Upvote or downvote content";
    }

    @PostMapping("/{id}/reports")
    public String report(@PathVariable String id) {
        service.get(id);
        return "Report content";
    }
[/if]
[if (m.name = 'Reddit' and rt.name = 'Post')]

    @PostMapping("/{id}/comments")
    public String commentOnPost(@PathVariable String id) {
        service.get(id);
        return "Reply to post";
    }
[/if]
[if (m.name = 'Reddit' and rt.name = 'Comment')]

    @PostMapping("/{id}/replies")
    public String replyToComment(@PathVariable String id) {
        service.get(id);
        return "Reply to comment thread";
    }
[/if]
}
[/file]
[/template]

[generateModelViews(m)/]
[generateGovernance(m)/]
[generateRuleBodies(m)/]
[generateDomain(m)/]
[generateInfra(m)/]
[generateSharedWebLayer(m)/]
[generateAppSpecificControllers(m)/]
[for (rt : ResourceType | m.resourceTypes)]
[generateRepository(m, rt)/]
[generateService(m, rt)/]
[if (not hasAppSpecificCrud(m, rt))]
[generateController(m, rt)/]
[/if]
[generateDomainResource(m, rt)/]
[generateDomainEntity(m, rt)/]
[/for]
[/template]

[template public generateApplication(m : RefModel)]

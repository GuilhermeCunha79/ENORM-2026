[comment encoding = UTF-8 /]
[module generate('http://www.example.org/enorm')/]

[query public baseName(m : RefModel) : String =
    if m.name.size() > 8 and m.name.substring(m.name.size() - 7, m.name.size()) = 'RefModel' then
        m.name.substring(1, m.name.size() - 8)
    else m.name
    endif
/]

[query public pkg(m : RefModel) : String = baseName(m).toLower() /]

[query public rootPath(m : RefModel) : String =
    pkg(m).concat('/src/generated/').concat(pkg(m))
/]

[query public basePackage(m : RefModel) : String = 'generated.'.concat(pkg(m)) /]
[query public domainPackage(m : RefModel) : String = basePackage(m).concat('.domain') /]
[query public domainGeneratedPackage(m : RefModel) : String = domainPackage(m).concat('.generated') /]
[query public domainEnumsPackage(m : RefModel) : String = domainPackage(m).concat('.enums') /]

[query public domainRootPath(m : RefModel) : String = rootPath(m).concat('/domain') /]
[query public domainGeneratedPath(m : RefModel) : String = domainRootPath(m).concat('/generated') /]
[query public domainEnumsPath(m : RefModel) : String = domainRootPath(m).concat('/enums') /]

[query public isRequiredCard(card : String) : Boolean = card = '1' /]
[query public relationFieldName(r : ResourceRelation) : String =
    if r.source = r.target then 'parent'
    else lowerFirst(r.source.name)
    endif
/]

[query public shouldSkipAttribute(a : Attribute) : Boolean = a.name.toLower() = 'id' /]
[query public javaType(p : PrimitiveType, multi : Boolean) : String =
    if multi then
        'java.util.List<'.concat(
            if p = PrimitiveType::TEXT then 'String'
            else if p = PrimitiveType::NUMBER then 'Double'
            else if p = PrimitiveType::BOOLEAN then 'Boolean'
            else if p = PrimitiveType::DATE then 'java.time.LocalDate'
            else if p = PrimitiveType::DATETIME then 'java.time.LocalDateTime'
            else if p = PrimitiveType::URL then 'java.net.URI'
            else if p = PrimitiveType::IMAGE then 'String'
            else if p = PrimitiveType::VIDEO then 'String'
            else 'String'
            endif endif endif endif endif endif endif endif
        ).concat('>')
    else
        if p = PrimitiveType::TEXT then 'String'
        else if p = PrimitiveType::NUMBER then 'Double'
        else if p = PrimitiveType::BOOLEAN then 'Boolean'
        else if p = PrimitiveType::DATE then 'java.time.LocalDate'
        else if p = PrimitiveType::DATETIME then 'java.time.LocalDateTime'
        else if p = PrimitiveType::URL then 'java.net.URI'
        else if p = PrimitiveType::IMAGE then 'String'
        else if p = PrimitiveType::VIDEO then 'String'
        else 'String'
        endif endif endif endif endif endif endif endif
    endif
/]

[query public defaultValue(a : Attribute) : String =
    if a.multiValued then ' = new java.util.ArrayList<>()'
    else ''
    endif
/]

[query public runtimeProfile(m : RefModel) : String =
    if baseName(m) = 'Amazon' then 'catalog-commerce'
    else if baseName(m) = 'Reddit' then 'community-platform'
    else if baseName(m) = 'YouTube' then 'media-platform'
    else 'generic-platform'
    endif endif endif
/]

[query public qString(s : String) : String =
    if s.oclIsUndefined() then 'null'
    else '\"'.concat(s).concat('\"')
    endif
/]

[query public qResource(r : ResourceType) : String =
    if r.oclIsUndefined() then 'null'
    else '\"'.concat(r.name).concat('\"')
    endif
/]

[query public qContext(c : ContextType) : String =
    if c.oclIsUndefined() then 'null'
    else '\"'.concat(c.name).concat('\"')
    endif
/]

[query public qFeedback(f : FeedbackDefinition) : String =
    if f.oclIsUndefined() then 'null'
    else '\"'.concat(f.name).concat('\"')
    endif
/]

[query public qAutomation(a : AutomationRule) : String =
    if a.oclIsUndefined() then 'null'
    else '\"'.concat(a.name).concat('\"')
    endif
/]


package [servicePackage(m)/];

import [serviceGeneratedPackage(m)/].GeneratedModerationService;
[if (baseName(m) = 'Reddit')]
import [domainPackage(m)/].Comment;
import [domainPackage(m)/].Post;
import [domainPackage(m)/].RedditUser;
import [domainPackage(m)/].Report;
import [domainEnumsPackage(m)/].ContentStatus;

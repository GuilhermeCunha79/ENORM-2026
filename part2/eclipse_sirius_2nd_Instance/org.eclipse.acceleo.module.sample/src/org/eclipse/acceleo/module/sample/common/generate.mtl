package [dtoPackage(m)/];

import java.net.URI;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.util.List;

public record [rt.name/]Dto(
        String id[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))] , [javaType(a.type, a.multiValued)/] [a.name/][/for]
) {}

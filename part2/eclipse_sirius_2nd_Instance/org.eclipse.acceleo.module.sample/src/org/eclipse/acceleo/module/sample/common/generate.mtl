[comment encoding = UTF-8 /]
[module generate('http://www.example.org/enorm')/]

[query public baseName(m : RefModel) : String = m.name /]
[query public pkg(m : RefModel) : String = m.name.toLowerFirst() /]
[query public projectRoot(m : RefModel) : String = 'src/generated/' + pkg(m) /]
[query public rootPath(m : RefModel) : String = projectRoot(m) + '/src/main/java/' + basePackage(m).replaceAll('\\.', '/') /]
[query public basePackage(m : RefModel) : String = 'generated.' + pkg(m) /]
[query public webPackage(m : RefModel) : String = basePackage(m) + '.web' /]
[query public webGeneratedPackage(m : RefModel) : String = webPackage(m) + '.generated' /]
[query public servicePackage(m : RefModel) : String = basePackage(m) + '.service' /]
[query public serviceGeneratedPackage(m : RefModel) : String = servicePackage(m) + '.generated' /]
[query public repositoryPackage(m : RefModel) : String = basePackage(m) + '.repository' /]
[query public repositoryGeneratedPackage(m : RefModel) : String = repositoryPackage(m) + '.generated' /]
[query public domainPackage(m : RefModel) : String = basePackage(m) + '.domain' /]
[query public domainGeneratedPackage(m : RefModel) : String = domainPackage(m) + '.generated' /]
[query public domainEnumsPackage(m : RefModel) : String = domainPackage(m) + '.enums' /]
[query public domainRootPath(m : RefModel) : String = rootPath(m) + '/domain' /]
[query public domainGeneratedPath(m : RefModel) : String = domainRootPath(m) + '/generated' /]
[query public domainEnumsPath(m : RefModel) : String = domainRootPath(m) + '/enums' /]
[query public webPath(m : RefModel) : String = rootPath(m) + '/web' /]
[query public webGeneratedPath(m : RefModel) : String = webPath(m) + '/generated' /]
[query public serviceGeneratedPath(m : RefModel) : String = rootPath(m) + '/service/generated' /]
[query public repositoryGeneratedPath(m : RefModel) : String = rootPath(m) + '/repository/generated' /]

[query public isMany(card : String) : Boolean = card = '*' or card = '0..*' or card = '1..*' /]
[query public shouldSkipAttribute(a : Attribute) : Boolean = a.name = 'id' or a.name = 'Id' /]
[query public sqlColumnName(name : String) : String = if name = 'value' then 'value_col' else if name = 'timestamp' then 'timestamp_col' else if name = 'date' then 'date_col' else if name = 'order' then 'order_col' else if name = 'user' then 'user_col' else if name = 'group' then 'group_col' else if name = 'key' then 'key_col' else name endif endif endif endif endif endif endif /]
[query public sqlTableName(name : String) : String = if name = 'Order' then 'orders' else if name = 'User' then 'users' else if name = 'Group' then 'groups' else if name = 'Key' then 'keys_table' else if name = 'Like' then 'likes_table' else name.toLowerFirst() endif endif endif endif endif /]
[query public hasAppSpecificCrud(m : RefModel, rt : ResourceType) : Boolean = if m.name = 'Reddit' then rt.name = 'Subreddit' or rt.name = 'Post' or rt.name = 'Comment' or rt.name = 'Vote' or rt.name = 'Subscription' or rt.name = 'Report' else if m.name = 'YouTube' then rt.name = 'Channel' or rt.name = 'Video' or rt.name = 'Comment' or rt.name = 'Like' or rt.name = 'Subscription' or rt.name = 'Report' else if m.name = 'Amazon' then rt.name = 'Product' or rt.name = 'Review' or rt.name = 'Comment' or rt.name = 'HelpfulVote' or rt.name = 'Order' else false endif endif endif /]
[query public baseJavaType(p : PrimitiveType) : String = if p = PrimitiveType::TEXT then 'String' else if p = PrimitiveType::NUMBER then 'Double' else if p = PrimitiveType::BOOLEAN then 'Boolean' else if p = PrimitiveType::DATE then 'LocalDate' else if p = PrimitiveType::DATETIME then 'LocalDateTime' else if p = PrimitiveType::URL then 'URI' else 'String' endif endif endif endif endif endif /]
[query public javaType(p : PrimitiveType, multi : Boolean) : String = if multi then 'List<' + baseJavaType(p) + '>' else baseJavaType(p) endif /]
[query public qText(s : String) : String = if s.oclIsUndefined() then 'null' else '\"' + s + '\"' endif /]
[query public qResource(r : ResourceType) : String = if r.oclIsUndefined() then 'null' else '\"' + r.name + '\"' endif /]
[query public qFeedback(f : FeedbackDefinition) : String = if f.oclIsUndefined() then 'null' else '\"' + f.name + '\"' endif /]
[query public qContext(c : ContextType) : String = if c.oclIsUndefined() then 'null' else '\"' + c.name + '\"' endif /]
[query public qAuthorizationContext(a : AuthorizationRule) : String = let eo : ecore::EObject = a.oclAsType(ecore::EObject) in let f : ecore::EStructuralFeature = if eo.oclIsUndefined() then null else eo.eClass().getEStructuralFeature('context') endif in if f.oclIsUndefined() then 'null' else qContext(eo.eGet(f).oclAsType(ContextType)) endif /]
[query public resourcePath(rt : ResourceType) : String = rt.name.toLowerFirst() + 's' /]
[query public relationEndpoint(r : ResourceRelation) : String = r.name.toLowerFirst() /]
[query public relationField(r : ResourceRelation) : String = if r.recursive then 'children' else r.target.name.toLowerFirst() + (if isMany(r.targetCardinality) then 's' else '' endif) endif /]
[query public runtimeProfile(m : RefModel) : String = if m.name = 'Amazon' then 'catalog-commerce' else if m.name = 'Reddit' then 'community-discussion' else if m.name = 'YouTube' then 'media-feedback' else 'generic-feedback' endif endif endif /]
[query public scenarioSummary(m : RefModel) : String = if m.name = 'YouTube' then 'Evaluated resources are videos; users comment videos, react with like/dislike, comments may thread, comments can be reported, and comments are commonly sorted by date or value.' else if m.name = 'Amazon' then 'Evaluated resources are bought products; users evaluate products with a five-star scale, text, optional photos/videos, and a verification process that may be manual or automatic.' else if m.name = 'Reddit' then 'Users post in topic forums, reply in threads, upvote/downvote posts and comments, report posts and comments, and each topic has rules, moderators, and automation support.' else 'Generated feedback REST API.' endif endif endif /]
[query public feedbackTargetKind(d : FeedbackDefinition) : String = if not d.subjectResource.oclIsUndefined() then 'RESOURCE' else if not d.subjectFeedback.oclIsUndefined() then 'FEEDBACK' else 'NONE' endif endif /]
[query public feedbackTargetName(d : FeedbackDefinition) : String = if not d.subjectResource.oclIsUndefined() then d.subjectResource.name else if not d.subjectFeedback.oclIsUndefined() then d.subjectFeedback.name else '' endif endif /]
[query public constName(s : String) : String = s.toUpper().replaceAll('[^A-Z0-9]+', '_') /]
[query public serverPort(m : RefModel) : String = if m.name = 'Amazon' then '8081' else if m.name = 'YouTube' then '8082' else if m.name = 'Reddit' then '8083' else '8080' endif endif endif /]

[template public generateElement(m : RefModel)]

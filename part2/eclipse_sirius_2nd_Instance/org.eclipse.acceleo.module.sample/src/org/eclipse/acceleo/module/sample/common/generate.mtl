[template public generateFeedback(m : RefModel)]
[file (rootPath(m) + '/model/Feedback.java', false, 'UTF-8')]
package generated.[pkg(m)/].model;

import java.util.List;

public final class Feedback {
private Feedback() {
}

public record FeedbackTypeSpec(String name, String kind, String subjectScope, boolean hasRating, boolean recursive, boolean allowsText, boolean allowsMedia, String polarity) {}
public record FeedbackDefinitionSpec(String name, boolean requiresVerifiedContext, String verificationRequirement, boolean uniquePerAuthorTarget, String type, String targetKind, String targetName, String author, String policyStatus, String ratingMin, String ratingMax, String ratingStep) {}

public static List<FeedbackTypeSpec> types() {
return List.of(
[for (t : FeedbackType | m.feedbackTypes) separator(',')]
new FeedbackTypeSpec("[t.name/]", "[t.kind/]", "[t.subjectScope/]", [t.hasRating/], [t.recursive/], [t.allowsText/], [t.allowsMedia/], "[t.polarity/]")
[/for]
);
}

public static List<FeedbackDefinitionSpec> definitions() {
return List.of(
[for (d : FeedbackDefinition | m.feedbackDefinitions) separator(',')]
new FeedbackDefinitionSpec("[d.name/]", [d.requiresVerifiedContext/], "[d.verificationRequirement/]", [d.uniquePerAuthorTarget/], "[d.type.name/]", "[feedbackTargetKind(d)/]", "[feedbackTargetName(d)/]", "[d.author.name/]", [if (d.policy.oclIsUndefined())]null[else]"[d.policy.status/]"[/if], [if (d.rating.oclIsUndefined())]null[else]"[d.rating.minValue/]"[/if], [if (d.rating.oclIsUndefined())]null[else]"[d.rating.maxValue/]"[/if], [if (d.rating.oclIsUndefined())]null[else]"[d.rating.step/]"[/if])
[/for]
);
}
}
[/file]
[/template]

[template public generateGovernance(m : RefModel)]
[file (rootPath(m) + '/governance/' + baseName(m) + 'Governance.java', false, 'UTF-8')]
package generated.[pkg(m)/].governance;

import java.util.List;

public final class [baseName(m)/]Governance {
private [baseName(m)/]Governance() {
}

public record AuthorizationSpec(String name, String allowedAction, String actor, String appContext, String resourceTarget, String feedbackTarget) {}
public record ValidationSpec(String name, String kind, String severity, String expression, String implementationBody, String appliesToResource, String appliesToFeedback, String invokedBy) {}
public record ModerationPolicySpec(String name, String mode, String trigger, String decision, String monitorsResource, String monitorsFeedback, List<String> executedBy, String inContext) {}
public record VerificationPolicySpec(String name, String mode, String appliesWhen, String verifies) {}
public record SortingPolicySpec(String name, String criterion, String direction, String appliesToResource, String appliesToFeedback, String inContext) {}

public static List<AuthorizationSpec> authorizations() {
return List.of(
[for (a : AuthorizationRule | m.authorizationRules) separator(',')]
new AuthorizationSpec("[a.name/]", "[a.allowedAction/]", "[a.actor.name/]", [qContext(a.context)/], "[a.resourceTarget.name/]", [qFeedback(a.feedbackTarget)/])
[/for]
);
}

public static List<ValidationSpec> validations() {
return List.of(
[for (v : ValidationRule | m.validationRules) separator(',')]
new ValidationSpec("[v.name/]", "[v.kind/]", "[v.severity/]", [qText(v.expression)/], [qText(v.implementationId)/], [qResource(v.appliesToResource)/], [qFeedback(v.appliesToFeedback)/], [qAutomation(v.invokedBy)/])
[/for]
);
}

public static List<ModerationPolicySpec> moderationPolicies() {
return List.of(
[for (p : ModerationPolicy | m.moderationPolicies) separator(',')]
new ModerationPolicySpec("[p.name/]", "[p.mode/]", "[p.trigger/]", "[p.decision/]", [qResource(p.monitorsResource)/], [qFeedback(p.monitorsFeedback)/], List.of([for (u : UserType | p.executedBy) separator(', ')]"[u.name/]"[/for]), [qContext(p.inContext)/])
[/for]
);
}

public static List<VerificationPolicySpec> verificationPolicies() {
return List.of(
[for (v : VerificationPolicy | m.verificationPolicies) separator(',')]
new VerificationPolicySpec("[v.name/]", "[v.mode/]", "[v.appliesWhen/]", "[v.verifies.name/]")
[/for]
);
}

public static List<SortingPolicySpec> sortingPolicies() {
return List.of(
[for (s : SortingPolicy | m.sortingPolicies) separator(',')]
new SortingPolicySpec("[s.name/]", "[s.criterion/]", "[s.direction/]", [qResource(s.appliesToResource)/], [qFeedback(s.appliesToFeedback)/], [qContext(s.inContext)/])
[/for]
);
}
}
[/file]
[/template]

[template public generateRuleBodies(m : RefModel)]
[file (rootPath(m) + '/runtime/RuleBodies.java', false, 'UTF-8')]
package generated.[pkg(m)/].runtime;

public final class RuleBodies {
private RuleBodies() {
}

[for (v : ValidationRule | m.validationRules)]
public static final String [constName(v.name)/]_EXPRESSION = [qText(v.expression)/];
public static final String [constName(v.name)/]_IMPLEMENTATION = [qText(v.implementationId)/];
[/for]
[for (a : AutomationRule | m.automationRules)]
[for (ac : Action | a.actions)]
public static final String [constName(a.name)/]_[constName(ac.name)/]_BODY = [qText(ac.message)/];
[/for]
[/for]
}
[/file]
[/template]

[template public generateDomain(m : RefModel)]
[generateDomainEnums(m)/]
[generateDomainContextType(m)/]
[generateDomainAuthorizationRule(m)/]
[generateDomainValidationRule(m)/]
[generateDomainModerationPolicy(m)/]
[generateDomainVerificationPolicy(m)/]
[generateDomainSortingPolicy(m)/]
[for (rt : ResourceType | m.resourceTypes)]
[generateDomainResource(m, rt)/]
[/for]
[/template]


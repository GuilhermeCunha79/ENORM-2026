[template public generateDomainResource(m : RefModel, rt : ResourceType)]
[file (domainGeneratedPath(m) + '/Generated' + rt.name + '.java', false, 'UTF-8')]
package [domainGeneratedPackage(m)/];

import java.net.URI;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.List;

public abstract class Generated[rt.name/] [if (rt.superTypes->notEmpty())]extends Generated[rt.superTypes->first().name/][/if] {
[if (rt.superTypes->isEmpty())]
private Long id;
[/if]
[for (a : Attribute | rt.attributes->select(a | not shouldSkipAttribute(a)))]
private [javaType(a.type, a.multiValued)/] [a.name/][if (a.multiValued)] = new ArrayList<[baseJavaType(a.type)/]>()[/if];
[/for]
[for (r : ResourceRelation | m.resourceRelations->select(r | r.source = rt))]
private [if (isMany(r.targetCardinality))]List<Generated[r.target.name/]>[else]Generated[r.target.name/][/if] [relationSourceFieldName(r)/][if (isMany(r.targetCardinality))] = new ArrayList<Generated[r.target.name/]>()[/if];
[/for]
[for (r : ResourceRelation | m.resourceRelations->select(r | r.target = rt))]
private Generated[r.source.name/] [relationTargetFieldName(r)/];
[/for]
}
[/file]
[/template]

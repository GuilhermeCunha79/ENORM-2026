<?xml version="1.0" encoding="UTF-8"?>
<description:Group xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:description="http://www.eclipse.org/sirius/description/1.1.0" xmlns:description_1="http://www.eclipse.org/sirius/diagram/description/1.1.0" xmlns:validation="http://www.eclipse.org/sirius/description/validation/1.1.0" name="enorm" version="12.0.0.2017041100">
  <ownedViewpoints name="enorm" modelFileExtension="enorm xmi">
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="RefModel Full Diagram" titleExpression="aql:self.name + ' - ' + self.version" domainClass="enorm.RefModel" enablePopupBars="true">
      <metamodel href="http://www.example.org/enorm#/"/>
      <validationSet>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C1.1 RefModel name not empty" level="ERROR" message="RefModel name must not be empty" targetClass="enorm.RefModel">
          <audits expression="aql:not self.name.oclIsUndefined() and self.name &lt;> ''"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C1.2 RefModel uppercase" level="WARNING" message="RefModel name should start with uppercase" targetClass="enorm.RefModel">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C1.3 RefModel name min length" level="ERROR" message="RefModel name must have more than 2 characters" targetClass="enorm.RefModel">
          <audits expression="aql:self.name.oclIsUndefined() or self.name.size() > 2"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C1.4 RefModel version semver" level="WARNING" message="Version should follow semantic versioning (e.g., 1.0.0)" targetClass="enorm.RefModel">
          <audits expression="aql:self.version.oclIsUndefined() or self.version.matches('[0-9]+\\.[0-9]+\\.[0-9]+')"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C2.1 UserType names unique" level="ERROR" message="UserType names must be unique within the model" targetClass="enorm.UserType">
          <audits expression="aql:self.eContainer().userTypes->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C2.2 UserType uppercase" level="WARNING" message="UserType name should start with uppercase" targetClass="enorm.UserType">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C2.3 UserType no self superType" level="ERROR" message="UserType cannot be its own supertype" targetClass="enorm.UserType">
          <audits expression="aql:not self.superTypes->includes(self)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C2.4 UserType no cycle" level="ERROR" message="UserType supertypes must not form a cycle" targetClass="enorm.UserType">
          <audits expression="aql:not self.superTypes->closure(s | s.superTypes)->includes(self)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C2.5 ContextType names unique" level="ERROR" message="ContextType names must be unique" targetClass="enorm.ContextType">
          <audits expression="aql:self.eContainer().contextTypes->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C2.6 ContextType uppercase" level="WARNING" message="ContextType name should start with uppercase" targetClass="enorm.ContextType">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.1 ResourceType names unique" level="ERROR" message="ResourceType names must be unique" targetClass="enorm.ResourceType">
          <audits expression="aql:self.eContainer().resourceTypes->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.2 ResourceType uppercase" level="WARNING" message="ResourceType name should start with uppercase" targetClass="enorm.ResourceType">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.3 ResourceType min length" level="ERROR" message="ResourceType name must have more than 2 characters" targetClass="enorm.ResourceType">
          <audits expression="aql:self.name.oclIsUndefined() or self.name.size() > 2"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.4 ResourceType no self superType" level="ERROR" message="ResourceType cannot be its own supertype" targetClass="enorm.ResourceType">
          <audits expression="aql:not self.superTypes->includes(self)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.5 ResourceType no cycle" level="ERROR" message="ResourceType supertypes must not form a cycle" targetClass="enorm.ResourceType">
          <audits expression="aql:not self.superTypes->closure(s | s.superTypes)->includes(self)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.6 Attribute names unique" level="ERROR" message="Attribute names must be unique within ResourceType" targetClass="enorm.Attribute">
          <audits expression="aql:self.eContainer().attributes->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.7 Attribute lowercase" level="WARNING" message="Attribute name should start with lowercase" targetClass="enorm.Attribute">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toLower()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.8 ResourceRelation source target different when non-recursive" level="ERROR" message="Non-recursive relation cannot have same source and target" targetClass="enorm.ResourceRelation">
          <audits expression="aql:self.recursive = true or self.source &lt;> self.target"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C3.9 ResourceRelation names unique" level="ERROR" message="ResourceRelation names must be unique within RefModel" targetClass="enorm.ResourceRelation">
          <audits expression="aql:self.eContainer().resourceRelations->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.1 FeedbackType names unique" level="ERROR" message="FeedbackType names must be unique within RefModel" targetClass="enorm.FeedbackType">
          <audits expression="aql:self.eContainer().feedbackTypes->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.2 FeedbackType uppercase" level="WARNING" message="FeedbackType name should start with uppercase" targetClass="enorm.FeedbackType">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.3 FeedbackDefinition target consistent with scope" level="ERROR" message="FeedbackDefinition target must be consistent with subjectScope" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:(self.type.subjectScope.toString() = 'RESOURCE_ONLY' implies (not self.subjectResource.oclIsUndefined() and self.subjectFeedback.oclIsUndefined())) and (self.type.subjectScope.toString() = 'FEEDBACK_ONLY' implies (not self.subjectFeedback.oclIsUndefined() and self.subjectResource.oclIsUndefined())) and (self.type.subjectScope.toString() = 'RESOURCE_OR_FEEDBACK' implies (not self.subjectResource.oclIsUndefined() or not self.subjectFeedback.oclIsUndefined()))"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.4 FeedbackDefinition names unique" level="ERROR" message="FeedbackDefinition names must be unique within RefModel" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.eContainer().feedbackDefinitions->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.5 FeedbackDefinition uppercase" level="WARNING" message="FeedbackDefinition name should start with uppercase" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.6 FeedbackDefinition author required" level="ERROR" message="FeedbackDefinition must have an author" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:not self.author.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.7 RatingPolicy only when hasRating" level="ERROR" message="RatingPolicy can only be set when FeedbackType.hasRating is true" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.rating.oclIsUndefined() or self.type.hasRating = true"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.8 RatingPolicy min less than max" level="ERROR" message="RatingPolicy minValue must be less than maxValue" targetClass="enorm.RatingPolicy">
          <audits expression="aql:self.minValue &lt; self.maxValue"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.9 RatingPolicy step positive and divides range" level="WARNING" message="RatingPolicy step must be positive and divide the range evenly" targetClass="enorm.RatingPolicy">
          <audits expression="aql:self.step > 0 and ((self.maxValue - self.minValue).mod(self.step) = 0)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.10 FeedbackPolicy DISABLED blocks creation" message="FeedbackDefinition with DISABLED policy will block new feedback creation at runtime" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.policy.oclIsUndefined() or self.policy.status.toString() &lt;> 'DISABLED' or true"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.11 subjectFeedback same type" level="WARNING" message="FeedbackDefinition subjectFeedback should be of the same FeedbackType" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.subjectFeedback.oclIsUndefined() or self.subjectFeedback.type = self.type"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C4.12 subjectFeedback not self" level="ERROR" message="FeedbackDefinition cannot target itself via subjectFeedback" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.subjectFeedback &lt;> self"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.1 ValidationRule target required" level="ERROR" message="ValidationRule must target at least one element" targetClass="enorm.ValidationRule">
          <audits expression="aql:not self.appliesToResource.oclIsUndefined() or not self.appliesToFeedback.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.2 ValidationRule names unique" level="ERROR" message="ValidationRule names must be unique within RefModel" targetClass="enorm.ValidationRule">
          <audits expression="aql:self.eContainer().validationRules->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.3 ValidationRule uppercase" level="WARNING" message="ValidationRule name should start with uppercase" targetClass="enorm.ValidationRule">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.4 ValidationRule implementationId min length" level="WARNING" message="ValidationRule implementationId must have at least 3 characters" targetClass="enorm.ValidationRule">
          <audits expression="aql:self.implementationId.oclIsUndefined() or self.implementationId.size() >= 3"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.5 ValidationRule expression required for AUTOMATIC" level="ERROR" message="ValidationRule expression must not be empty when kind is AUTOMATIC" targetClass="enorm.ValidationRule">
          <audits expression="aql:self.kind.toString() &lt;> 'AUTOMATIC' or (not self.expression.oclIsUndefined() and self.expression &lt;> '')"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.6 ModerationPolicy names unique" level="ERROR" message="ModerationPolicy names must be unique within RefModel" targetClass="enorm.ModerationPolicy">
          <audits expression="aql:self.eContainer().moderationPolicies->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.7 ModerationPolicy executedBy required" level="ERROR" message="ModerationPolicy must have executedBy" targetClass="enorm.ModerationPolicy">
          <audits expression="aql:not self.executedBy.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.8 ModerationPolicy trigger required for AUTOMATIC" level="ERROR" message="ModerationPolicy trigger must not be empty when mode is AUTOMATIC" targetClass="enorm.ModerationPolicy">
          <audits expression="aql:self.mode.toString() &lt;> 'AUTOMATIC' or not self.trigger.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.9 AuthorizationRule actor required" level="ERROR" message="AuthorizationRule must have an actor" targetClass="enorm.AuthorizationRule">
          <audits expression="aql:not self.actor.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.10 AuthorizationRule both targets required" level="ERROR" message="AuthorizationRule must have a resourceTarget" targetClass="enorm.AuthorizationRule">
          <audits expression="aql:not self.resourceTarget.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.11 AutomationRule names unique" level="ERROR" message="AutomationRule names must be unique within RefModel" targetClass="enorm.AutomationRule">
          <audits expression="aql:self.eContainer().automationRules->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.12 AutomationRule uppercase" level="WARNING" message="AutomationRule name should start with uppercase" targetClass="enorm.AutomationRule">
          <audits expression="aql:self.name.oclIsUndefined() or self.name = '' or self.name.substring(1,1) = self.name.substring(1,1).toUpper()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.13 AutomationRule trigger not empty" level="ERROR" message="AutomationRule trigger must not be empty" targetClass="enorm.AutomationRule">
          <audits expression="aql:not self.trigger.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.15 VerificationPolicy names unique" level="ERROR" message="VerificationPolicy names must be unique within RefModel" targetClass="enorm.VerificationPolicy">
          <audits expression="aql:self.eContainer().verificationPolicies->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C5.16 VerificationPolicy verifies required" level="ERROR" message="VerificationPolicy must verify a FeedbackDefinition" targetClass="enorm.VerificationPolicy">
          <audits expression="aql:not self.verifies.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G1 hasRating requires rating" level="ERROR" message="FeedbackDefinition with hasRating=true must define a RatingPolicy" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.type.hasRating = false or not self.rating.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G2 REVIEW resource only" level="ERROR" message="REVIEW feedback must use subjectScope=RESOURCE_ONLY" targetClass="enorm.FeedbackType">
          <audits expression="aql:self.kind.toString() &lt;> 'REVIEW' or self.subjectScope.toString() = 'RESOURCE_ONLY'"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G3 REACTION VOTE flags" level="ERROR" message="REACTION/VOTE must have hasRating=false and recursive=false" targetClass="enorm.FeedbackType">
          <audits expression="aql:(self.kind.toString() &lt;> 'REACTION' and self.kind.toString() &lt;> 'VOTE') or (self.hasRating = false and self.recursive = false)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G3 REACTION VOTE no rating policy" level="ERROR" message="REACTION/VOTE feedback cannot define RatingPolicy" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:((self.type.kind.toString() &lt;> 'REACTION') and (self.type.kind.toString() &lt;> 'VOTE')) or self.rating.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G4 SUBSCRIPTION resource only and non recursive" level="ERROR" message="SUBSCRIPTION feedback must be RESOURCE_ONLY and non-recursive" targetClass="enorm.FeedbackType">
          <audits expression="aql:self.kind.toString() &lt;> 'SUBSCRIPTION' or (self.subjectScope.toString() = 'RESOURCE_ONLY' and self.recursive = false)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G5 recursive feedback supports feedback targets" level="ERROR" message="Recursive feedback must allow FEEDBACK targets" targetClass="enorm.FeedbackType">
          <audits expression="aql:self.recursive = false or self.subjectScope.toString() &lt;> 'RESOURCE_ONLY'"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G6 RESOURCE_ONLY forbids subjectFeedback" level="ERROR" message="RESOURCE_ONLY feedback cannot set subjectFeedback" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.type.subjectScope.toString() &lt;> 'RESOURCE_ONLY' or self.subjectFeedback.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G7 FEEDBACK_ONLY forbids subjectResource" level="ERROR" message="FEEDBACK_ONLY feedback cannot set subjectResource" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.type.subjectScope.toString() &lt;> 'FEEDBACK_ONLY' or self.subjectResource.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G8 verified context requires verification policy" level="ERROR" message="FeedbackDefinition requiring verified context must have a VerificationPolicy" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.requiresVerifiedContext = false or self.eContainer().verificationPolicies->exists(vp | vp.verifies = self)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G9 uniquePerAuthorTarget single target" level="ERROR" message="uniquePerAuthorTarget requires a single target to avoid ambiguity" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:self.uniquePerAuthorTarget = false or self.subjectResource.oclIsUndefined() or self.subjectFeedback.oclIsUndefined()"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G10 AuthorizationRule context contains resourceTarget" level="ERROR" message="AuthorizationRule resourceTarget must belong to the selected context" targetClass="enorm.AuthorizationRule">
          <audits expression="aql:self.context.oclIsUndefined() or self.resourceTarget.oclIsUndefined() or self.context.contains->includes(self.resourceTarget)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G11 ModerationPolicy inContext contains monitorsResource" level="ERROR" message="ModerationPolicy monitorsResource must belong to the selected context" targetClass="enorm.ModerationPolicy">
          <audits expression="aql:self.inContext.oclIsUndefined() or self.monitorsResource.oclIsUndefined() or self.inContext.contains->includes(self.monitorsResource)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G12 AutomationRule inContext contains context" level="ERROR" message="AutomationRule context resource must belong to the selected context" targetClass="enorm.AutomationRule">
          <audits expression="aql:self.inContext.oclIsUndefined() or self.context.oclIsUndefined() or self.inContext.contains->includes(self.context)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G13 Product reviews rating based and policy" level="ERROR" message="Product reviews must be rating-based and define a RatingPolicy" targetClass="enorm.FeedbackDefinition">
          <audits expression="aql:not (self.type.kind.toString() = 'REVIEW' and not self.subjectResource.oclIsUndefined() and self.subjectResource.name = 'Product') or (self.type.hasRating = true and not self.rating.oclIsUndefined())"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G14 Product rating 1..5 integer" level="ERROR" message="Product star rating must use min=1, max=5, step=1" targetClass="enorm.RatingPolicy">
          <audits expression="aql:self.eContainer().oclIsKindOf(enorm::FeedbackDefinition) = false or let fd = self.eContainer() in not (fd.type.kind.toString() = 'REVIEW' and not fd.subjectResource.oclIsUndefined() and fd.subjectResource.name = 'Product') or (self.minValue = 1 and self.maxValue = 5 and self.step = 1)"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G15 SortingPolicy DATE requires DATE attribute" level="ERROR" message="SortingPolicy with criterion=DATE requires appliesToResource to have at least one DATE attribute" targetClass="enorm.SortingPolicy">
          <audits expression="aql:self.criterion.toString() &lt;> 'DATE' or (not self.appliesToResource.oclIsUndefined() and self.appliesToResource.attributes->exists(a | a.type.toString() = 'DATE'))"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="G16 Condition attribute belongs to AutomationRule context" level="ERROR" message="Condition.attribute must belong to AutomationRule.context" targetClass="enorm.Condition">
          <audits expression="aql:not self.attribute.oclIsUndefined() and (self.eContainer().oclIsUndefined() or self.eContainer().context.oclIsUndefined() or self.eContainer().context.attributes->includes(self.attribute))"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C6.1 EvolutionRule names unique" level="ERROR" message="EvolutionRule names must be unique within RefModel" targetClass="enorm.EvolutionRule">
          <audits expression="aql:self.eContainer().evolutionRules->select(x | x.name = self.name)->size() = 1"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C6.2 EvolutionRule versions differ" level="ERROR" message="EvolutionRule fromVersion must be different from toVersion" targetClass="enorm.EvolutionRule">
          <audits expression="aql:self.fromVersion.oclIsUndefined() or self.toVersion.oclIsUndefined() or self.fromVersion &lt;> self.toVersion"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C6.3 EvolutionRule operations required" level="ERROR" message="EvolutionRule must define at least one RefactoringOperation" targetClass="enorm.EvolutionRule">
          <audits expression="aql:not self.operations.oclIsUndefined() and self.operations->size() > 0"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C6.4 RefactoringOperation name not empty" level="ERROR" message="RefactoringOperation name must not be empty" targetClass="enorm.RefactoringOperation">
          <audits expression="aql:not self.name.oclIsUndefined() and self.name &lt;> ''"/>
        </ownedRules>
        <ownedRules xsi:type="validation:SemanticValidationRule" name="C6.5 RefactoringOperation scriptId min length" level="WARNING" message="RefactoringOperation scriptId must have at least 3 characters" targetClass="enorm.RefactoringOperation">
          <audits expression="aql:self.scriptId.oclIsUndefined() or self.scriptId.size() >= 3"/>
        </ownedRules>
      </validationSet>
      <defaultLayer name="Default">
        <nodeMappings name="UserType" semanticCandidatesExpression="feature:userTypes" domainClass="enorm.UserType">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="ContextType" semanticCandidatesExpression="feature:contextTypes" domainClass="enorm.ContextType">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="ResourceRelation" semanticCandidatesExpression="feature:resourceRelations" domainClass="enorm.ResourceRelation">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="FeedbackType" semanticCandidatesExpression="feature:feedbackTypes" domainClass="enorm.FeedbackType">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="AuthorizationRule" semanticCandidatesExpression="feature:authorizationRules" domainClass="enorm.AuthorizationRule">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="ValidationRule" semanticCandidatesExpression="feature:validationRules" domainClass="enorm.ValidationRule">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="ModerationPolicy" semanticCandidatesExpression="feature:moderationPolicies" domainClass="enorm.ModerationPolicy">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="VerificationPolicy" semanticCandidatesExpression="feature:verificationPolicies" domainClass="enorm.VerificationPolicy">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <nodeMappings name="SortingPolicy" semanticCandidatesExpression="feature:sortingPolicies" domainClass="enorm.SortingPolicy">
          <style xsi:type="description_1:SquareDescription"/>
        </nodeMappings>
        <edgeMappings name="UserType.superTypes" semanticCandidatesExpression="feature:userTypes" sourceMapping="//@ownedViewpoints[name='enorm']/@ownedRepresentations[name='RefModel%20Full%20Diagram']/@defaultLayer/@nodeMappings[name='UserType']" targetMapping="//@ownedViewpoints[name='enorm']/@ownedRepresentations[name='RefModel%20Full%20Diagram']/@defaultLayer/@nodeMappings[name='UserType']" targetFinderExpression="feature:superTypes" sourceFinderExpression="var:self" domainClass="enorm.UserType" useDomainElement="true">

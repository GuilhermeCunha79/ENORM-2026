    {
      "name": "04 Policy - load moderation policy and resolve inputs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{moderatorToken}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/api/policies/moderation"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Policy seed endpoint returns 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const policies = pm.response.json();",
              "pm.test(\"Moderation policies are seeded\", function () {",
              "  pm.expect(policies).to.be.an(\"array\").that.is.not.empty;",
              "});",
              "",
              "const expectedCount = parseInt(pm.collectionVariables.get(\"expectedPolicyCount\") || \"0\", 10);",
              "if (expectedCount > 0) {",
              "  pm.test(\"Policy count matches this backend\", function () {",
              "    pm.expect(policies.length).to.equal(expectedCount);",
              "  });",
              "}",
              "",
              "const policy = policies[0] || {};",
              "const targetType = policy.monitorsFeedback || policy.monitorsResource || pm.collectionVariables.get(\"targetType\");",
              "const policyResourceTargetType = policy.monitorsResource || pm.collectionVariables.get(\"policyResourceTargetType\");",
              "const policyFeedbackTargetType = policy.monitorsFeedback || pm.collectionVariables.get(\"policyFeedbackTargetType\");",
              "const trigger = policy.trigger || pm.collectionVariables.get(\"trigger\");",
              "",
              "pm.test(\"Policy targetType and trigger are resolved\", function () {",
              "  pm.expect(targetType, \"targetType\").to.be.a(\"string\").and.not.empty;",
              "  pm.expect(policyResourceTargetType, \"policyResourceTargetType\").to.be.a(\"string\").and.not.empty;",
              "  pm.expect(policyFeedbackTargetType, \"policyFeedbackTargetType\").to.be.a(\"string\").and.not.empty;",
              "  pm.expect(trigger, \"trigger\").to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.collectionVariables.set(\"targetType\", targetType);",
              "pm.collectionVariables.set(\"policyResourceTargetType\", policyResourceTargetType);",
              "pm.collectionVariables.set(\"policyFeedbackTargetType\", policyFeedbackTargetType);",
              "pm.collectionVariables.set(\"trigger\", trigger);",
              "",
              "const wrongTargetCandidates = [",
              "  pm.collectionVariables.get(\"wrongTargetType\"),",
              "  \"ProductReview\",",
              "  \"CommentReview\",",
              "  \"ReportOnPost\",",
              "  \"ReportOnComment\",",
              "  \"ReportOnVideo\",",
              "  \"Video\",",
              "  \"Comment\",",
              "  \"Post\"",
              "].filter(Boolean);",
              "const wrongTargetType = wrongTargetCandidates.find(function (candidate) {",
              "  return candidate !== targetType;",
              "}) || (targetType + \"_WRONG\");",
              "",
              "let wrongTrigger = pm.collectionVariables.get(\"wrongTrigger\") || \"ON_FEEDBACK_CREATE\";",
              "if (wrongTrigger === trigger) {",
              "  wrongTrigger = trigger === \"ON_REPORT_THRESHOLD\" ? \"ON_FEEDBACK_CREATE\" : \"ON_REPORT_THRESHOLD\";",
              "}",
              "",
              "pm.collectionVariables.set(\"wrongTargetType\", wrongTargetType);",
              "pm.collectionVariables.set(\"wrongTrigger\", wrongTrigger);"
            ]
          }
        }
      ]
    },

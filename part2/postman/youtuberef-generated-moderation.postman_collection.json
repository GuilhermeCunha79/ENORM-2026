    {
      "name": "09 Auto (resource) - simulate auto-trigger moderation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{moderatorToken}}",
            "type": "text"
          }
        ],
        "url": "{{baseUrl}}/api/moderation/simulate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetType\": \"{{resourceAutoTargetType}}\",\n  \"targetId\": {{resourceId}},\n  \"trigger\": \"ON_RESOURCE_CREATE\",\n  \"content\": \"{{resourceContent}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Automatic-hook equivalent moderation request returns 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "const expectedStatus = pm.collectionVariables.get(\"expectedAutoStatus\") || \"SKIPPED\";",
              "const expectMatch = String(pm.collectionVariables.get(\"expectedAutoMatchedKeyword\") || \"false\").toLowerCase() === \"true\";",
              "const keyword = pm.collectionVariables.get(\"blockedKeyword\");",
              "",
              "pm.test(\"Automatic-hook equivalent status matches current MPS policy wiring\", function () {",
              "  pm.expect(body.status).to.equal(expectedStatus);",
              "});",
              "",
              "if (expectMatch) {",
              "  pm.test(\"Automatic-hook equivalent matched the configured keyword\", function () {",
              "    const matched = (body.matchedKeywords || []).map(String);",
              "    pm.expect(matched).to.include(keyword);",
              "  });",
              "} else {",
              "  pm.test(\"Automatic-hook equivalent has no matched keywords in current MPS wiring\", function () {",
              "    pm.expect(body.matchedKeywords || []).to.be.an(\"array\").that.is.empty;",
              "  });",
              "}",
              "",
              "pm.collectionVariables.set(\"autoStatus\", body.status);"
            ]
          }
        }
      ]
    },
